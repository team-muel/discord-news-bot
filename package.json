{
  "name": "muel-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:server",
    "dev:server": "tsx server.ts",
    "dev:bot": "tsx bot.ts",
    "build": "node scripts/build-backend.mjs",
    "start": "npm run start:server",
    "start:server": "node --import tsx server.ts",
    "start:bot": "node --import tsx bot.ts",
    "pm2:start": "npx pm2 start ecosystem.config.cjs --update-env",
    "pm2:restart": "npx pm2 restart muel-backend --update-env",
    "pm2:stop": "npx pm2 stop muel-backend",
    "pm2:logs": "npx pm2 logs muel-backend",
    "pm2:status": "npx pm2 status",
    "pm2:save": "npx pm2 save",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "env:check": "node scripts/validate-env.mjs",
    "env:profile:local": "node scripts/apply-env-profile.mjs local",
    "env:profile:production": "node scripts/apply-env-profile.mjs production",
    "env:profile:local:dry": "node scripts/apply-env-profile.mjs local --dry-run",
    "env:profile:production:dry": "node scripts/apply-env-profile.mjs production --dry-run",
    "mcp:dev": "tsx scripts/mcp-stdio.ts",
    "worker:crawler": "tsx scripts/crawler-worker.ts",
    "sync:obsidian-lore": "tsx scripts/sync-obsidian-lore.ts",
    "sync:obsidian-lore:dry": "tsx scripts/sync-obsidian-lore.ts --dry-run",
    "obsidian:verify-write": "tsx scripts/verify-obsidian-write.ts",
    "obsidian:audit-graph": "tsx scripts/audit-obsidian-graph.ts",
    "obsidian:code-map": "tsx scripts/sync-obsidian-code-map.ts",
    "obsidian:code-map:watch": "tsx scripts/sync-obsidian-code-map.ts --watch",
    "obsidian:bootstrap-guild": "tsx scripts/bootstrap-obsidian-guild.ts",
    "obsidian:ops-cycle": "tsx scripts/run-obsidian-knowledge-cycle.ts",
    "obsidian:ops-loop": "tsx scripts/run-obsidian-knowledge-loop.ts",
    "obsidian:openjarvis:flow": "node scripts/export-openjarvis-flow-to-obsidian.mjs --latest",
    "obsidian:openjarvis:flow:custom": "node scripts/export-openjarvis-flow-to-obsidian.mjs",
    "check:drift": "node scripts/check-operational-drift.mjs",
    "seed:retrieval-eval": "tsx scripts/bootstrap-retrieval-eval.ts",
    "seed:retrieval-eval:dry": "tsx scripts/bootstrap-retrieval-eval.ts --dry-run",
    "privacy:backfill-memory-owner": "tsx scripts/backfill-memory-owner-user.ts",
    "seed:research-presets": "tsx scripts/seed-research-presets.ts",
    "memory:backfill-discord": "tsx scripts/backfill-discord-memory.ts",
    "memory:queue:report": "node scripts/report-memory-queue-weekly.mjs --days=7 --sinks=markdown,supabase",
    "memory:queue:report:dry": "node scripts/report-memory-queue-weekly.mjs --days=7 --dryRun=true --sinks=markdown,supabase",
    "memory:queue:report:stdout": "node scripts/report-memory-queue-weekly.mjs --days=7 --sinks=stdout",
    "bench:obsidian-search": "tsx scripts/bench-obsidian-search.ts",
    "smoke:api": "node scripts/smoke-api.mjs",
    "load:bot-status": "node scripts/load-bot-status.mjs",
    "rehearsal:stage-rollback": "node scripts/rehearse-stage-rollback.mjs",
    "rehearsal:stage-rollback:record": "node scripts/run-stage-rollback-rehearsal.mjs",
    "rehearsal:stage-rollback:record:dry": "node scripts/run-stage-rollback-rehearsal.mjs --dryRun=true",
    "rehearsal:stage-rollback:validate": "node scripts/validate-stage-rollback-readiness.mjs --maxSummaryAgeHours=48 --maxRecoveryMinutes=10 --maxFailCount=0",
    "rehearsal:stage-rollback:validate:strict": "node scripts/validate-stage-rollback-readiness.mjs --maxSummaryAgeHours=36 --maxRecoveryMinutes=10 --maxFailCount=0 --allowZeroRuns=true",
    "trading:isolation:validate": "node scripts/validate-trading-isolation-readiness.mjs",
    "trading:canary:readiness": "node scripts/run-trading-canary-readiness.mjs",
    "perf:llm-latency": "node scripts/report-llm-latency.mjs",
    "perf:llm-latency:weekly": "node scripts/generate-llm-latency-weekly-report.mjs --sinks=supabase,obsidian",
    "perf:llm-latency:weekly:dry": "node scripts/generate-llm-latency-weekly-report.mjs --dryRun=true --sinks=supabase,obsidian",
    "perf:llm-latency:weekly:md": "node scripts/generate-llm-latency-weekly-report.mjs --sinks=markdown",
    "perf:llm-latency:weekly:md:dry": "node scripts/generate-llm-latency-weekly-report.mjs --dryRun=true --sinks=markdown",
    "docs:routes": "node scripts/generate-route-inventory.mjs",
    "routes:check:agent": "node scripts/verify-bot-agent-routes.mjs",
    "docs:deps": "node scripts/generate-dependency-graph.mjs",
    "docs:schema-map": "node scripts/generate-schema-service-map.mjs",
    "docs:build": "npm run docs:routes && npm run docs:deps && npm run docs:schema-map",
    "docs:check": "npm run docs:build && git diff --exit-code -- docs/ROUTES_INVENTORY.md docs/DEPENDENCY_GRAPH.md docs/SCHEMA_SERVICE_MAP.md",
    "contracts:validate": "node scripts/validate-autonomy-contracts.mjs",
    "gates:init-log": "node scripts/create-go-no-go-log.mjs",
    "gates:auto-judge": "node scripts/auto-judge-go-no-go.mjs",
    "gates:auto-judge:example": "node scripts/auto-judge-go-no-go.mjs --stage=A --scope=guild:demo --operator=auto --thresholdProfile=progressive_autonomy_v1 --p95LatencyMs=420 --queueLagSec=30 --errorRatePct=0.8 --citationRate=0.78 --retrievalHitAtK=0.72 --hallucinationReviewFailRate=0.05 --sessionSuccessRate=0.91 --approvalRequiredCompliancePct=100 --unapprovedAutodeployCount=0 --policyViolationCount=0 --privacyBlockCount=0 --roadmapSynced=true --executionBoardSynced=true --backlogSynced=true --runbookSynced=true --changelogSynced=true",
    "gates:auto-judge:weekly": "node scripts/auto-judge-from-weekly.mjs --stage=A --scope=weekly:auto --thresholdProfile=stage_default --minQualitySamples=3 --runAfterFallback=true",
    "gates:auto-judge:weekly:pending": "node scripts/auto-judge-from-weekly.mjs --stage=A --scope=weekly:auto --thresholdProfile=stage_default --allowPending=true --minQualitySamples=3 --runAfterFallback=true",
    "gates:weekly-report": "node scripts/summarize-go-no-go-runs.mjs",
    "gates:weekly-report:dry": "node scripts/summarize-go-no-go-runs.mjs --days=7 --dryRun=true",
    "gates:weekly-report:supabase": "node scripts/summarize-go-no-go-runs.mjs --days=7 --sinks=markdown,supabase",
    "gates:weekly-report:supabase:dry": "node scripts/summarize-go-no-go-runs.mjs --days=7 --dryRun=true --sinks=markdown,supabase",
    "gates:weekly-report:normalized": "node scripts/summarize-go-no-go-runs.mjs --days=7 --legacyPendingCutoff=2026-03-19T00:00:00.000Z --excludeLegacyPendingNoGo=true --output=docs/planning/gate-runs/WEEKLY_SUMMARY_NORMALIZED.md",
    "gates:weekly-report:normalized:dry": "node scripts/summarize-go-no-go-runs.mjs --days=7 --dryRun=true --legacyPendingCutoff=2026-03-19T00:00:00.000Z --excludeLegacyPendingNoGo=true --output=docs/planning/gate-runs/WEEKLY_SUMMARY_NORMALIZED.md",
    "gates:weekly-report:hybrid": "node scripts/generate-hybrid-weekly-report.mjs --days=7 --sinks=supabase,markdown",
    "gates:weekly-report:hybrid:dry": "node scripts/generate-hybrid-weekly-report.mjs --days=7 --dryRun=true --sinks=supabase,markdown",
    "gates:weekly-report:self-improvement": "node scripts/generate-self-improvement-weekly.mjs --days=7 --sinks=markdown",
    "gates:weekly-report:self-improvement:dry": "node scripts/generate-self-improvement-weekly.mjs --days=7 --dryRun=true --sinks=markdown,stdout",
    "gates:weekly-report:rollback": "node scripts/summarize-rollback-rehearsals.mjs --days=7 --sinks=markdown,supabase",
    "gates:weekly-report:rollback:dry": "node scripts/summarize-rollback-rehearsals.mjs --days=7 --dryRun=true --sinks=markdown,supabase",
    "gates:weekly-report:all": "npm run gates:weekly-report:supabase && npm run perf:llm-latency:weekly && npm run gates:weekly-report:hybrid && npm run gates:weekly-report:rollback && npm run memory:queue:report && npm run gates:weekly-report:self-improvement && npm run gates:auto-judge:weekly:pending",
    "gates:weekly-report:all:dry": "npm run gates:weekly-report:supabase:dry && npm run perf:llm-latency:weekly:dry && npm run gates:weekly-report:hybrid:dry && npm run gates:weekly-report:rollback:dry && npm run memory:queue:report:dry && npm run gates:weekly-report:self-improvement:dry",
    "gates:validate": "node scripts/validate-go-no-go-runs.mjs",
    "gates:validate:strict": "node scripts/validate-go-no-go-runs.mjs --requireChecklist=true --checklistSinceDays=1 && npm run rehearsal:stage-rollback:validate:strict",
    "gates:fixtures:check": "node scripts/validate-go-no-go-runs.mjs --dir=docs/planning/gate-runs/fixtures --requireNoGo=true",
    "test:contracts": "vitest run src/services/autonomyContractSchemas.test.ts",
    "openjarvis:autonomy:run": "node scripts/run-openjarvis-unattended.mjs --strict=true",
    "openjarvis:autonomy:run:dry": "node scripts/run-openjarvis-unattended.mjs --dryRun=true --strict=true"
  },
  "dependencies": {
    "@sentry/node": "^7.59.0",
    "@supabase/supabase-js": "^2.98.0",
    "better-sqlite3": "^12.4.1",
    "ccxt": "^4.5.42",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.2",
    "tsx": "^4.21.0",
    "winston": "^3.9.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.4.1",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.1.0",
    "madge": "^8.0.0",
    "rimraf": "^5.0.0",
    "typescript": "~5.8.2",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "undici": "^6.24.0"
  }
}
