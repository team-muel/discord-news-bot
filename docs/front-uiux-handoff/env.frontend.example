# Backend base URL for frontend API calls.
# Local: http://localhost:3000
# Prod:  https://<backend-domain>
VITE_API_BASE_URL=http://localhost:3000

# Optional: where popup postMessage should be accepted from.
# If omitted, use VITE_API_BASE_URL origin.
VITE_OAUTH_POPUP_ORIGIN=http://localhost:3000
