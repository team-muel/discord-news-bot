{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "muel.autonomy.contracts.v1",
  "title": "Progressive Autonomy Contract Set",
  "type": "object",
  "required": [
    "eventEnvelope",
    "commandEnvelope",
    "policyDecisionRecord",
    "evidenceBundle"
  ],
  "properties": {
    "eventEnvelope": {
      "$ref": "#/$defs/eventEnvelope"
    },
    "commandEnvelope": {
      "$ref": "#/$defs/commandEnvelope"
    },
    "policyDecisionRecord": {
      "$ref": "#/$defs/policyDecisionRecord"
    },
    "evidenceBundle": {
      "$ref": "#/$defs/evidenceBundle"
    },
    "localCollabTaskEnvelope": {
      "$ref": "#/$defs/localCollabTaskEnvelope"
    },
    "localCollabRouteResponse": {
      "$ref": "#/$defs/localCollabRouteResponse"
    },
    "localCollabConsultResponse": {
      "$ref": "#/$defs/localCollabConsultResponse"
    },
    "localCollabSynthesizeResponse": {
      "$ref": "#/$defs/localCollabSynthesizeResponse"
    }
  },
  "$defs": {
    "agentRole": {
      "type": "string",
      "enum": ["OpenCode", "OpenDev", "NemoClaw", "OpenJarvis"]
    },
    "routeMode": {
      "type": "string",
      "enum": ["local-collab", "delivery", "operations"]
    },
    "timingHint": {
      "type": "string",
      "enum": ["before-edit", "during-implementation", "before-release", "already-consulted", "during-review", "during-validation", "before-implementation"]
    },
    "leadAgent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "reason"],
      "properties": {
        "name": { "$ref": "#/$defs/agentRole" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "consultAgent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "reason", "timing"],
      "properties": {
        "name": { "$ref": "#/$defs/agentRole" },
        "reason": { "type": "string", "minLength": 1 },
        "timing": { "$ref": "#/$defs/timingHint" }
      }
    },
    "promptHandoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["next_owner", "reason", "expected_outcome"],
      "properties": {
        "next_owner": { "$ref": "#/$defs/agentRole" },
        "reason": { "type": "string", "minLength": 1 },
        "expected_outcome": { "type": "string", "minLength": 1 }
      }
    },
    "promptEscalation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "target_mode", "reason"],
      "properties": {
        "required": { "type": "boolean" },
        "target_mode": { "$ref": "#/$defs/routeMode" },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "requiredGates": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["typecheck", "tests", "security", "ops-readiness", "regression-check", "architecture-alignment", "rollback-readiness"]
      },
      "uniqueItems": true
    },
    "localCollabTaskEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "guild_id",
        "objective",
        "constraints",
        "risk_level",
        "acceptance_criteria",
        "inputs",
        "budget"
      ],
      "properties": {
        "task_id": { "type": "string", "minLength": 1 },
        "guild_id": { "type": "string", "minLength": 1 },
        "objective": { "type": "string", "minLength": 1 },
        "constraints": {
          "type": ["array", "string"],
          "items": { "type": "string" }
        },
        "risk_level": { "type": "string", "minLength": 1 },
        "acceptance_criteria": {
          "type": ["array", "string"],
          "items": { "type": "string" }
        },
        "inputs": {
          "type": ["object", "array", "string"]
        },
        "budget": {
          "type": ["object", "string"]
        },
        "current_stage": { "type": "string" },
        "lead_agent": { "$ref": "#/$defs/agentRole" },
        "consult_agent": { "$ref": "#/$defs/agentRole" },
        "current_state": { "type": ["object", "array", "string"] },
        "changed_files": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "consult_results": {
          "type": ["object", "array", "string"]
        }
      }
    },
    "eventEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "event_type",
        "event_version",
        "occurred_at",
        "guild_id",
        "actor_id",
        "payload",
        "trace_id"
      ],
      "properties": {
        "event_id": { "type": "string", "minLength": 1 },
        "event_type": { "type": "string", "minLength": 1 },
        "event_version": { "type": "integer", "minimum": 1 },
        "occurred_at": { "type": "string", "format": "date-time" },
        "guild_id": { "type": "string", "minLength": 1 },
        "actor_id": { "type": "string", "minLength": 1 },
        "payload": { "type": "object" },
        "trace_id": { "type": "string", "minLength": 1 }
      }
    },
    "commandEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_id",
        "command_type",
        "requested_by",
        "requested_at",
        "idempotency_key",
        "policy_context",
        "payload"
      ],
      "properties": {
        "command_id": { "type": "string", "minLength": 1 },
        "command_type": { "type": "string", "minLength": 1 },
        "requested_by": { "type": "string", "minLength": 1 },
        "requested_at": { "type": "string", "format": "date-time" },
        "idempotency_key": { "type": "string", "minLength": 1 },
        "policy_context": { "type": "object" },
        "payload": { "type": "object" }
      }
    },
    "policyDecisionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "reasons",
        "risk_score",
        "budget_state",
        "review_required",
        "approved_by"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["allow", "deny", "review"]
        },
        "reasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "risk_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "budget_state": {
          "type": "string",
          "enum": ["normal", "warning", "blocked"]
        },
        "review_required": { "type": "boolean" },
        "approved_by": {
          "type": ["string", "null"],
          "minLength": 1
        }
      }
    },
    "evidenceBundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ok",
        "summary",
        "artifacts",
        "verification",
        "error",
        "retry_hint",
        "runtime_cost"
      ],
      "properties": {
        "ok": { "type": "boolean" },
        "summary": { "type": "string" },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type", "uri"],
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "uri": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "verification": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["check", "status"],
            "properties": {
              "check": { "type": "string" },
              "status": { "type": "string", "enum": ["pass", "fail", "skip"] },
              "details": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "error": {
          "type": ["string", "null"]
        },
        "retry_hint": {
          "type": ["string", "null"]
        },
        "runtime_cost": {
          "type": "object",
          "required": ["latency_ms", "token_in", "token_out"],
          "properties": {
            "latency_ms": { "type": "number", "minimum": 0 },
            "token_in": { "type": "number", "minimum": 0 },
            "token_out": { "type": "number", "minimum": 0 },
            "usd": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": true
        }
      }
    },
    "localCollabRouteResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "guild_id",
        "mode",
        "lead_agent",
        "consult_agents",
        "required_gates",
        "handoff",
        "escalation",
        "next_action"
      ],
      "properties": {
        "task_id": { "type": "string", "minLength": 1 },
        "guild_id": { "type": "string", "minLength": 1 },
        "mode": { "$ref": "#/$defs/routeMode" },
        "lead_agent": { "$ref": "#/$defs/leadAgent" },
        "consult_agents": {
          "type": "array",
          "maxItems": 2,
          "items": { "$ref": "#/$defs/consultAgent" }
        },
        "required_gates": { "$ref": "#/$defs/requiredGates" },
        "handoff": { "$ref": "#/$defs/promptHandoff" },
        "escalation": { "$ref": "#/$defs/promptEscalation" },
        "next_action": { "type": "string", "minLength": 1 }
      }
    },
    "localCollabConsultResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "guild_id",
        "lead_agent",
        "consult_agent",
        "summary",
        "recommendations",
        "risks",
        "required_gates",
        "handoff",
        "escalation",
        "next_action"
      ],
      "properties": {
        "task_id": { "type": "string", "minLength": 1 },
        "guild_id": { "type": "string", "minLength": 1 },
        "lead_agent": { "$ref": "#/$defs/leadAgent" },
        "consult_agent": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "reason"],
          "properties": {
            "name": { "$ref": "#/$defs/agentRole" },
            "reason": { "type": "string", "minLength": 1 }
          }
        },
        "summary": { "type": "string", "minLength": 1 },
        "recommendations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "risks": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "required_gates": { "$ref": "#/$defs/requiredGates" },
        "handoff": { "$ref": "#/$defs/promptHandoff" },
        "escalation": { "$ref": "#/$defs/promptEscalation" },
        "next_action": { "type": "string", "minLength": 1 }
      }
    },
    "localCollabSynthesizeResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "guild_id",
        "lead_agent",
        "consult_agents",
        "decision_summary",
        "required_gates",
        "handoff",
        "escalation",
        "next_action"
      ],
      "properties": {
        "task_id": { "type": "string", "minLength": 1 },
        "guild_id": { "type": "string", "minLength": 1 },
        "lead_agent": { "$ref": "#/$defs/leadAgent" },
        "consult_agents": {
          "type": "array",
          "maxItems": 2,
          "items": { "$ref": "#/$defs/consultAgent" }
        },
        "decision_summary": { "type": "string", "minLength": 1 },
        "required_gates": { "$ref": "#/$defs/requiredGates" },
        "handoff": { "$ref": "#/$defs/promptHandoff" },
        "escalation": { "$ref": "#/$defs/promptEscalation" },
        "next_action": { "type": "string", "minLength": 1 }
      }
    }
  }
}
