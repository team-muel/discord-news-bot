# Balanced profile (availability/quality/latency balance)
AI_PROVIDER=openclaw
LLM_PROVIDER_AUTOMATIC_FALLBACK_ENABLED=false
LLM_PROVIDER_MAX_ATTEMPTS=2
LLM_PROVIDER_TOTAL_TIMEOUT_MS=25000
LLM_API_TIMEOUT_MS=15000
LLM_PROVIDER_POLICY_ACTIONS=intent.route=openclaw,gemini;tot.self_eval=openclaw,openai;planner.action_chain=openclaw,gemini

AGENT_SESSION_TIMEOUT_MS=120000
AGENT_STEP_TIMEOUT_MS=45000
AGENT_SESSION_MAX_ATTEMPTS=1
DISCORD_SESSION_PROGRESS_TIMEOUT_MS=180000

AGENT_DYNAMIC_REASONING_BUDGET_ENABLED=true
AGENT_DYNAMIC_REASONING_LOW_GOAL_LENGTH=120
AGENT_DYNAMIC_REASONING_HIGH_GOAL_LENGTH=320

PLANNER_SELF_CONSISTENCY_ENABLED=true
PLANNER_SELF_CONSISTENCY_SAMPLES=2
FINAL_SELF_CONSISTENCY_ENABLED=true
FINAL_SELF_CONSISTENCY_SAMPLES=2

TOT_SHADOW_ENABLED=true
TOT_SHADOW_MAX_BRANCHES=2
TOT_REPLAY_TOP_K=1
TOT_LOCAL_SEARCH_MUTATIONS=1
GOT_SHADOW_ENABLED=true
GOT_ACTIVE_ENABLED=false

OPS_EXECUTION_ACTION_RUNNER_ENABLED=true
ACTION_RETRY_MAX=1
ACTION_TIMEOUT_MS=12000
ACTION_FINOPS_DEGRADED_RETRY_MAX=1
ACTION_FINOPS_DEGRADED_TIMEOUT_MS=8000
