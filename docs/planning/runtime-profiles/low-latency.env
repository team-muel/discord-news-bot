# Low-latency profile (interactive UX first)
AI_PROVIDER=openjarvis
LLM_PROVIDER_AUTOMATIC_FALLBACK_ENABLED=true
LLM_PROVIDER_MAX_ATTEMPTS=1
LLM_PROVIDER_TOTAL_TIMEOUT_MS=15000
LLM_API_TIMEOUT_MS=12000
LLM_PROVIDER_POLICY_ACTIONS=intent.route=openjarvis,ollama;ltm.decompose=ollama,openjarvis;tot.self_eval=ollama,openjarvis;planner.action_chain=ollama,openjarvis

AGENT_SESSION_TIMEOUT_MS=90000
AGENT_STEP_TIMEOUT_MS=30000
AGENT_SESSION_MAX_ATTEMPTS=1
DISCORD_SESSION_PROGRESS_TIMEOUT_MS=120000

AGENT_DYNAMIC_REASONING_BUDGET_ENABLED=true
AGENT_DYNAMIC_REASONING_LOW_GOAL_LENGTH=140
AGENT_DYNAMIC_REASONING_HIGH_GOAL_LENGTH=360

PLANNER_SELF_CONSISTENCY_ENABLED=true
PLANNER_SELF_CONSISTENCY_SAMPLES=1
FINAL_SELF_CONSISTENCY_ENABLED=true
FINAL_SELF_CONSISTENCY_SAMPLES=1

TOT_SHADOW_ENABLED=false
GOT_SHADOW_ENABLED=true
GOT_ACTIVE_ENABLED=false

OPS_EXECUTION_ACTION_RUNNER_ENABLED=true
ACTION_RETRY_MAX=1
ACTION_TIMEOUT_MS=10000
ACTION_FINOPS_DEGRADED_RETRY_MAX=0
ACTION_FINOPS_DEGRADED_TIMEOUT_MS=6000
