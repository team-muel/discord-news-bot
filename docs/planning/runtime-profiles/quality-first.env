# Quality-first profile (deeper reasoning with guarded latency)
AI_PROVIDER=openjarvis
LLM_PROVIDER_AUTOMATIC_FALLBACK_ENABLED=true
LLM_PROVIDER_MAX_ATTEMPTS=2
LLM_PROVIDER_TOTAL_TIMEOUT_MS=35000
LLM_API_TIMEOUT_MS=18000
LLM_PROVIDER_POLICY_ACTIONS=intent.route=openjarvis,litellm;tot.self_eval=openjarvis,litellm;planner.action_chain=openjarvis,litellm

AGENT_SESSION_TIMEOUT_MS=150000
AGENT_STEP_TIMEOUT_MS=55000
AGENT_SESSION_MAX_ATTEMPTS=1
DISCORD_SESSION_PROGRESS_TIMEOUT_MS=210000

AGENT_DYNAMIC_REASONING_BUDGET_ENABLED=true
AGENT_DYNAMIC_REASONING_LOW_GOAL_LENGTH=100
AGENT_DYNAMIC_REASONING_HIGH_GOAL_LENGTH=260

PLANNER_SELF_CONSISTENCY_ENABLED=true
PLANNER_SELF_CONSISTENCY_SAMPLES=3
FINAL_SELF_CONSISTENCY_ENABLED=true
FINAL_SELF_CONSISTENCY_SAMPLES=3

TOT_SHADOW_ENABLED=true
TOT_SHADOW_MAX_BRANCHES=3
TOT_REPLAY_TOP_K=2
TOT_LOCAL_SEARCH_MUTATIONS=1
GOT_SHADOW_ENABLED=true
GOT_ACTIVE_ENABLED=true

OPS_EXECUTION_ACTION_RUNNER_ENABLED=true
ACTION_RETRY_MAX=2
ACTION_TIMEOUT_MS=15000
ACTION_FINOPS_DEGRADED_RETRY_MAX=1
ACTION_FINOPS_DEGRADED_TIMEOUT_MS=8000
