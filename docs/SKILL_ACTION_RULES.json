{
  "ragIntentPattern": "rag|근거|출처|기억|메모리|memory|회상|리콜|retrieve|retrieval|요약근거",
  "rules": [
    {
      "id": "local-orchestrator-all-intent",
      "pattern": "ALL\\.|all agents|full.?orchestrat|전체.?에이전트|전체.?오케스트레이션|풀.?오케스트레이션",
      "plans": [
        {
          "actionName": "local.orchestrator.all",
          "reason": "local-orchestrator-all-intent",
          "queryArg": "goal"
        }
      ]
    },
    {
      "id": "local-orchestrator-intent",
      "pattern": "orchestrator|local.?collab|lead.?agent|consult.?agent|multi.?agent|라우팅|오케스트레이터|리드.?에이전트|협업.?에이전트",
      "plans": [
        {
          "actionName": "local.orchestrator.route",
          "reason": "local-orchestrator-intent",
          "queryArg": "goal"
        }
      ]
    },
    {
      "id": "architecture-intent",
      "pattern": "architecture|adr|boundary|contract|milestone|roadmap|plan|설계|아키텍처|경계|계약|마일스톤|로드맵|실행 계획",
      "plans": [
        {
          "actionName": "opendev.plan",
          "reason": "architecture-intent",
          "queryArg": "goal"
        }
      ]
    },
    {
      "id": "review-risk-intent",
      "pattern": "review|regression|risk|security|test gap|release gate|리뷰|회귀|리스크|보안|테스트 누락|릴리스 게이트",
      "plans": [
        {
          "actionName": "nemoclaw.review",
          "reason": "review-risk-intent",
          "queryArg": "goal"
        }
      ]
    },
    {
      "id": "ops-intent",
      "pattern": "ops|operations|deploy|release|rollback|runbook|workflow|automation|운영|배포|릴리스|롤백|런북|워크플로|자동화",
      "plans": [
        {
          "actionName": "openjarvis.ops",
          "reason": "ops-intent",
          "queryArg": "goal"
        }
      ]
    },
    {
      "id": "privacy-forget-user-intent",
      "pattern": "잊어|잊혀|forget|erase|삭제|지워|파기|개인정보|프라이버시|gdpr|탈퇴",
      "plans": [
        {
          "actionName": "privacy.forget.user",
          "reason": "privacy-forget-user-intent",
          "queryArg": "none"
        }
      ]
    },
    {
      "id": "privacy-forget-guild-intent",
      "pattern": "(길드|서버).*(삭제|파기|초기화|잊어)|guild.*(delete|remove|forget)|서버.*추방",
      "plans": [
        {
          "actionName": "privacy.forget.guild",
          "reason": "privacy-forget-guild-intent",
          "queryArg": "none"
        }
      ]
    },
    {
      "id": "rag-intent",
      "pattern": "rag|근거|출처|기억|메모리|memory|회상|리콜|retrieve|retrieval|요약근거",
      "plans": [
        {
          "actionName": "rag.retrieve",
          "reason": "rag-intent",
          "queryArg": "goal"
        }
      ]
    },
    {
      "id": "youtube-intent",
      "pattern": "youtube|유튜브",
      "plans": [
        {
          "actionName": "youtube.search.first",
          "reason": "youtube-intent",
          "queryArg": "goal"
        }
      ],
      "conditionalPlans": [
        {
          "when": "웹훅|webhook|알림|전송|post|notify",
          "plans": [
            {
              "actionName": "youtube.search.webhook",
              "reason": "youtube-webhook-intent",
              "queryArg": "goal"
            }
          ]
        }
      ]
    },
    {
      "id": "chart-intent",
      "pattern": "차트|chart",
      "plans": [
        {
          "actionName": "stock.chart",
          "reason": "chart-intent",
          "queryArg": "none"
        }
      ]
    },
    {
      "id": "quote-intent",
      "pattern": "주가|가격|quote",
      "plans": [
        {
          "actionName": "stock.quote",
          "reason": "quote-intent",
          "queryArg": "none"
        }
      ]
    },
    {
      "id": "analysis-intent",
      "pattern": "분석|analysis",
      "plans": [
        {
          "actionName": "investment.analysis",
          "reason": "analysis-intent",
          "queryArg": "goal"
        }
      ]
    },
    {
      "id": "coding-intent",
      "pattern": "코드|코딩|구현|함수|클래스|버그|리팩터|script|typescript|javascript|python|sql|api\\s*만들|코드\\s*짜",
      "plans": [
        {
          "actionName": "code.generate",
          "reason": "coding-intent",
          "queryArg": "goal"
        }
      ]
    },
    {
      "id": "opencode-intent",
      "pattern": "터미널|tui|cli|명령어\\s*실행|자동화\\s*워커|opencode|swe-agent|실행\\s*해줘",
      "plans": [
        {
          "actionName": "opencode.execute",
          "reason": "opencode-intent",
          "queryArg": "goal"
        }
      ]
    },
    {
      "id": "news-intent",
      "pattern": "뉴스|news|헤드라인|기사",
      "plans": [
        {
          "actionName": "news.google.search",
          "reason": "news-intent",
          "queryArg": "goal"
        }
      ]
    },
    {
      "id": "news-verify-intent",
      "pattern": "검증|팩트체크|교차확인|사실(이야|인가|맞아)|fact.?check|verify|cross.?check",
      "plans": [
        {
          "actionName": "news.verify",
          "reason": "news-verify-intent",
          "queryArg": "goal"
        }
      ]
    },
    {
      "id": "community-intent",
      "pattern": "커뮤니티|community|게시글|포럼|reddit|디시|클리앙|루리웹|블라인드",
      "plans": [
        {
          "actionName": "community.search",
          "reason": "community-intent",
          "queryArg": "goal"
        }
      ]
    },
    {
      "id": "web-intent",
      "pattern": "웹\\s*검색|웹검색|web\\s*search|search|자료\\s*찾|url|링크|http",
      "plans": [
        {
          "actionName": "web.search",
          "reason": "web-intent",
          "queryArg": "goal"
        }
      ],
      "conditionalPlans": [
        {
          "when": "https?://|url|링크",
          "plans": [
            {
              "actionName": "web.fetch",
              "reason": "web-fetch-intent",
              "queryArg": "none"
            }
          ]
        }
      ]
    },
    {
      "id": "db-intent",
      "pattern": "db|database|데이터베이스|supabase|메모리\\s*조회|기억\\s*조회|lore",
      "plans": [
        {
          "actionName": "db.supabase.read",
          "reason": "db-intent",
          "queryArg": "none"
        }
      ]
    },
    {
      "id": "obsidian-write-intent",
      "pattern": "옵시디언|obsidian|문서\\s*저장|노트\\s*저장|기록\\s*해줘|정리\\s*해줘",
      "plans": [
        {
          "actionName": "obsidian.guild_doc.upsert",
          "reason": "obsidian-write-intent",
          "queryArg": "goal"
        }
      ]
    }
  ]
}
