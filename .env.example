# Server
PORT=3000
# Comma-separated allowed origins for frontend apps
# Example: FRONTEND_ORIGIN=https://muel-front-uiux.vercel.app,http://localhost:5173
FRONTEND_ORIGIN=

# Bot behavior
# 24/7 server+bot operation requires START_BOT=true and a valid DISCORD token.
# true/1: server process also starts Discord bot
# false/0: server-only mode
START_BOT=true
DISCORD_READY_TIMEOUT_MS=15000
DISCORD_START_RETRIES=3

# Automation worker bot (legacy Python auto-run bridge)
# Keep enabled for always-on news/youtube automation jobs.
START_AUTOMATION_BOT=true
AUTOMATION_RUN_ON_START=true
AUTOMATION_PERSISTENT_WORKERS=true
AUTOMATION_RESTART_DELAY_MS=5000
AUTOMATION_PYTHON_COMMAND=python
AUTOMATION_NEWS_ENABLED=true
AUTOMATION_NEWS_INTERVAL_MIN=30
AUTOMATION_NEWS_CRON=*/30 * * * *
AUTOMATION_NEWS_SCRIPT=bot_task.py
AUTOMATION_YOUTUBE_ENABLED=true
AUTOMATION_YOUTUBE_INTERVAL_MIN=10
AUTOMATION_YOUTUBE_CRON=*/10 * * * *
AUTOMATION_YOUTUBE_SCRIPT=youtube_monitor.py

# Discord
DISCORD_TOKEN=
# Optional alternative token variable name
DISCORD_BOT_TOKEN=
TARGET_CHANNEL_ID=

# External integrations
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_KEY=
SENTRY_DSN=

# Logging
LOG_LEVEL=info
NODE_ENV=development

# Auth
JWT_SECRET=change-me-in-production
AUTH_COOKIE_NAME=muel_session

# Admin allowlist for research preset mutation APIs (comma-separated user IDs)
RESEARCH_PRESET_ADMIN_USER_IDS=
