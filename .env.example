# Server
PORT=3000
# Deployment profile hint for scripts/validate-env.mjs
# auto | api-only | bot-only | full | prod
DEPLOYMENT_PROFILE=auto
# Public URL used to build OAuth callback when DISCORD_OAUTH_REDIRECT_URI is omitted.
# Example: PUBLIC_BASE_URL=https://muel-service.onrender.com
PUBLIC_BASE_URL=
# Comma-separated allowed origins for frontend apps
# Example: FRONTEND_ORIGIN=https://muel-front-uiux.vercel.app,http://localhost:5173
FRONTEND_ORIGIN=
# Alias for frontend allowlist (also used by OAuth popup postMessage origin)
OAUTH_REDIRECT_ALLOWLIST=

# Bot behavior
# 24/7 server+bot operation requires START_BOT=true and a valid DISCORD token.
# true/1: server process also starts Discord bot
# false/0: server-only mode
START_BOT=true
START_TRADING_BOT=false
DISCORD_READY_TIMEOUT_MS=45000
DISCORD_START_RETRIES=3
DISCORD_MESSAGE_CONTENT_INTENT_ENABLED=true
# In local development, keep the API process alive even if Discord login fails once.
BOT_START_FAILURE_EXIT_ENABLED=false
DISCORD_CLEAR_GUILD_COMMANDS_ON_GLOBAL_SYNC=false
DISCORD_AUTO_LOGIN_ON_FIRST_COMMAND=true
# Control-plane cache/rate standards (W3)
BOT_STATUS_CACHE_TTL_MS=5000
BOT_STATUS_RATE_WINDOW_MS=60000
BOT_STATUS_RATE_MAX=60
BOT_ADMIN_ACTION_RATE_WINDOW_MS=60000
BOT_ADMIN_ACTION_RATE_MAX=20
API_IDEMPOTENCY_TTL_SEC=86400

# Node automation monitor
START_AUTOMATION_JOBS=false
AUTOMATION_YOUTUBE_ENABLED=true
AUTOMATION_YOUTUBE_INTERVAL_MIN=10
AUTOMATION_NEWS_ENABLED=true
AUTOMATION_NEWS_INTERVAL_MIN=10
GOOGLE_FINANCE_NEWS_URL=https://www.google.com/finance/markets?hl=ko
NEWS_MONITOR_INTERVAL_MS=600000
NEWS_MONITOR_LOCK_LEASE_MS=120000
# scrape failure warning cooldown (minutes)
AUTOMATION_YOUTUBE_SCRAPE_ALERT_COOLDOWN_MIN=60
YOUTUBE_MONITOR_INTERVAL_MS=300000
YOUTUBE_MONITOR_CONCURRENCY=5
YOUTUBE_MONITOR_LOCK_LEASE_MS=120000

# Discord
DISCORD_TOKEN=
# Optional alternative token variable name
DISCORD_BOT_TOKEN=

# External integrations
# LLM provider routing (litellm | openclaw | ollama | anthropic | openai | gemini | kimi | huggingface)
# LiteLLM proxy is the primary provider — it routes model aliases (muel-balanced,
# muel-fast, muel-precise) to underlying backends (Gemini, OpenAI, Anthropic).
# OpenClaw Gateway is reserved for session-aware agent calls (Phase 4+).
AI_PROVIDER=litellm
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=

# ── LiteLLM Proxy (primary inference routing) ──
# Set LITELLM_BASE_URL to your deployed LiteLLM proxy.
# Auto-enabled when URL is non-localhost. Model aliases defined in litellm.config.yaml.
LITELLM_BASE_URL=https://muel-litellm-proxy.onrender.com
LITELLM_MASTER_KEY=
LITELLM_MODEL=muel-balanced
# Model alias → backend mapping (see litellm.config.yaml):
#   muel-balanced → gemini/gemini-2.5-flash
#   muel-fast     → openai/gpt-4o-mini
#   muel-precise  → anthropic/claude-3-5-sonnet-latest
#   muel-local    → ollama/qwen2.5:7b-instruct
#   muel-hf       → huggingface/Qwen/Qwen2.5-7B-Instruct
#   muel-nemotron → nvidia_nim/nvidia/nemotron-3-super-120b-a12b

# ── OpenClaw Gateway (session-aware agent inference) ──
# Enable when OpenClaw agent is running and cmdop gRPC server is available.
# This enables agent.chat with multi-turn sessions and tool calling.
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_ENABLED=true
# OpenClaw adapter (tool execution: agent.chat, skill.create, session.relay)
OPENCLAW_ENABLED=false
# Auto-create OpenClaw skills for lacuna (missing action) candidates
OPENCLAW_LACUNA_SKILL_CREATE_ENABLED=false
# OpenClaw completions fallback (used when Gateway is unavailable but OpenClaw provider selected)
# Leave empty to skip OpenClaw provider and fall through to LiteLLM.
OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=
OPENCLAW_MODEL=openclaw
# Optional model fallback chain when primary model is quota-limited.
OPENCLAW_FALLBACK_MODELS=
OPENCLAW_MODEL_COOLDOWN_DEFAULT_MS=45000
# Hugging Face Inference API (https://huggingface.co/settings/tokens)
HF_TOKEN=
# Alias keys recognized by runtime/validator
HF_API_KEY=
HUGGINGFACE_API_KEY=
# Provider ordering: litellm → openclaw → ollama → cloud providers
# Default built-in order: openclaw,litellm,ollama,anthropic,openai,gemini,kimi,huggingface,openjarvis
LLM_PROVIDER_BASE_ORDER=litellm,openclaw,ollama,anthropic,openai,gemini,huggingface
# Declarative provider fallback chain used when provider is not explicitly fixed per request.
LLM_PROVIDER_FALLBACK_CHAIN=litellm,openclaw,ollama,anthropic,openai,gemini,huggingface
# Automatic fallback to the built-in provider order when explicit chain is empty.
# Recommended true for agent-driven workloads (availability > latency).
LLM_PROVIDER_AUTOMATIC_FALLBACK_ENABLED=true
# Maximum providers to try per request (including the selected provider)
LLM_PROVIDER_MAX_ATTEMPTS=3
# Hard cap for total provider-chain time budget per request (ms)
LLM_PROVIDER_TOTAL_TIMEOUT_MS=25000
# Action-level provider policy map (semicolon or newline separated)
# Format: actionPattern=provider1,provider2
# Example: rag.retrieve=openclaw,huggingface;web.search*=openclaw,openai
# Example(advanced): intent.route=openclaw,litellm;security.*=openclaw,anthropic
LLM_PROVIDER_POLICY_ACTIONS=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_TRADES_TABLE=trades
# Single Render default: local in-process execution path.
# Set `proxy` only when delegating to an external AI-trading service.
AI_TRADING_MODE=local
AI_TRADING_DRY_RUN=false
AI_TRADING_BASE_URL=
AI_TRADING_INTERNAL_TOKEN=
AI_TRADING_ORDER_PATH=/internal/binance/order
AI_TRADING_POSITION_PATH=/internal/binance/position
AI_TRADING_TIMEOUT_MS=15000
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_FUTURES=true
BINANCE_HEDGE_MODE=false
BINANCE_SPOT_MIN_BASE_QTY=0.000001
TRADING_DRY_RUN=true
TRADING_EXCHANGE=binance
TRADING_SYMBOLS=BTC/USDT
TRADING_TIMEFRAME=30m
TRADING_CVD_LEN=19
TRADING_DELTA_COEF=1.0
TRADING_RISK_PCT=2.0
TRADING_TP_PCT=4.0
TRADING_SL_PCT=2.0
TRADING_LEVERAGE=20
TRADING_INITIAL_CAPITAL=3000
TRADING_EQUITY_SPLIT=true
TRADING_POLL_SECONDS=20
TRADING_CANDLE_LOOKBACK=400
TRADING_TICK_FETCH_LIMIT=1000
TRADING_TICK_MAX_PAGES=3
TRADING_CANDLES_TABLE=candles
TRADING_STATE_TABLE=bot_state
MAX_MANUAL_TRADE_QTY=10000
MAX_MANUAL_TRADE_LEVERAGE=125
MAX_MANUAL_TRADE_ENTRY_PRICE=10000000
SENTRY_DSN=

# Logging
LOG_LEVEL=info
NODE_ENV=development

# Auth
JWT_SECRET=change-me-in-production
AUTH_COOKIE_NAME=muel_session
DEV_AUTH_ENABLED=true
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
# Optional: if empty, backend uses `${PUBLIC_BASE_URL}/api/auth/callback`.
DISCORD_OAUTH_REDIRECT_URI=
DISCORD_OAUTH_SCOPE=identify
DISCORD_OAUTH_API_BASE=https://discord.com/api
DISCORD_INVITE_PERMISSIONS=8
DISCORD_INVITE_SCOPES=bot applications.commands
DISCORD_OAUTH_STATE_COOKIE_NAME=muel_oauth_state
DISCORD_OAUTH_STATE_TTL_SEC=600
# OAuth aliases to reduce key count
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Admin allowlist for research preset mutation APIs (comma-separated user IDs)
RESEARCH_PRESET_ADMIN_USER_IDS=
ADMIN_ALLOWLIST_TABLE=user_roles
ADMIN_ALLOWLIST_ROLE_VALUE=admin
ADMIN_ALLOWLIST_CACHE_TTL_MS=300000

# Optional local cron sync: Obsidian markdown -> Supabase guild_lore_docs
OBSIDIAN_SYNC_VAULT_PATH=
# Optional defaults used by manifest-driven guild sync when no per-guild manifest exists
OBSIDIAN_SYNC_DEFAULT_INCLUDE_GLOBS=**/*.md
OBSIDIAN_SYNC_DEFAULT_EXCLUDE_GLOBS=.obsidian/**,.trash/**,templates/**,ops/state/**,index/**
OBSIDIAN_SYNC_DEFAULT_MAX_FILES=600
# Optional folder->guild mapping (JSON object as string)
# Example: {"alpha-server":"123456789012345678","beta-lab":"234567890123456789"}
OBSIDIAN_SYNC_GUILD_MAP_JSON=
# Optional path to JSON mapping file (used when OBSIDIAN_SYNC_GUILD_MAP_JSON is empty)
OBSIDIAN_SYNC_GUILD_MAP_FILE=
# Optional Discord webhook URL for sync summary notifications
OBSIDIAN_SYNC_DISCORD_WEBHOOK_URL=
# Optional runtime loop: periodically run obsidian lore sync script from bot process.
OBSIDIAN_SYNC_LOOP_ENABLED=false
OBSIDIAN_SYNC_LOOP_INTERVAL_MIN=60
OBSIDIAN_SYNC_LOOP_RUN_ON_START=true
OBSIDIAN_SYNC_LOOP_TIMEOUT_MS=600000

# ──── Obsidian Native CLI (1.12.7+) ────
# Requires Obsidian 1.12.7+ with bundled CLI binary (Obsidian.com on Windows).
# Significantly faster than headless/Electron approach. Supports search, backlinks, tags, read, write.
OBSIDIAN_NATIVE_CLI_ENABLED=false
OBSIDIAN_NATIVE_CLI_PATH=
OBSIDIAN_NATIVE_CLI_LORE_MAX_HINTS=8
OBSIDIAN_NATIVE_CLI_LORE_MAX_CHARS=280
OBSIDIAN_NATIVE_CLI_TIMEOUT_MS=10000

# ──── Obsidian Headless CLI (RAG Integration) ────
# Prerequisites: npm install -g obsidian-headless (global install)
# Then authenticate: ob login --email <email> --password <password>
# 
# Obsidian Headless allows vault access without the desktop app.
# Falls back to file-based reading if CLI unavailable.
OBSIDIAN_HEADLESS_ENABLED=true
OBSIDIAN_EMAIL=
OBSIDIAN_PASSWORD=
OBSIDIAN_VAULT_NAME=docs
# Adapter routing order for vault operations. Available: native-cli, headless-cli, script-cli, local-fs
OBSIDIAN_ADAPTER_ORDER=native-cli,headless-cli,script-cli,local-fs
# Capability-specific adapter order (recommended: native-first, headless fallback, local-fs last)
OBSIDIAN_ADAPTER_ORDER_READ_LORE=native-cli,headless-cli,script-cli,local-fs
OBSIDIAN_ADAPTER_ORDER_SEARCH_VAULT=native-cli,headless-cli,local-fs
OBSIDIAN_ADAPTER_ORDER_READ_FILE=native-cli,headless-cli,local-fs
OBSIDIAN_ADAPTER_ORDER_GRAPH_METADATA=native-cli,headless-cli,local-fs
OBSIDIAN_ADAPTER_ORDER_WRITE_NOTE=native-cli,local-fs,script-cli
# Strict mode: do not fallback to secondary adapter when primary returns empty.
OBSIDIAN_ADAPTER_STRICT=false
OBSIDIAN_HEADLESS_COMMAND=ob
OBSIDIAN_HEADLESS_LORE_MAX_HINTS=6
OBSIDIAN_HEADLESS_LORE_MAX_CHARS=220
# Strict mode for post-write verification chain in obsidian.guild_doc.upsert.
OBSIDIAN_POST_WRITE_VERIFY_STRICT=false
# Local in-memory search index TTL in milliseconds (stale-while-revalidate).
OBSIDIAN_LOCAL_INDEX_TTL_MS=15000
# Local search scoring weights (text/title/tag/connectivity/recency)
OBSIDIAN_SEARCH_WEIGHT_TEXT=1
OBSIDIAN_SEARCH_WEIGHT_TITLE=1.2
OBSIDIAN_SEARCH_WEIGHT_TAG=2.5
OBSIDIAN_SEARCH_WEIGHT_CONNECTIVITY=1.1
OBSIDIAN_SEARCH_WEIGHT_RECENCY=1.3
# Recency half-life used by local search ranking
OBSIDIAN_SEARCH_RECENCY_HALFLIFE_HOURS=72
# Graph audit thresholds (quality gates)
OBSIDIAN_AUDIT_REQUIRED_PROPERTIES=schema,source,guild_id,title,category,updated_at
OBSIDIAN_AUDIT_MAX_UNRESOLVED=50
OBSIDIAN_AUDIT_MAX_AMBIGUOUS=20
OBSIDIAN_AUDIT_MAX_ORPHANS=200
OBSIDIAN_AUDIT_MAX_DEADENDS=200
OBSIDIAN_AUDIT_MAX_MISSING_PROPERTIES=50
# Code map for Sourcetrail-like Obsidian navigation
OBSIDIAN_CODEMAP_REPO_PATH=
OBSIDIAN_CODEMAP_VAULT_PATH=
OBSIDIAN_CODEMAP_OUTPUT_DIR=index/code-map
OBSIDIAN_CODEMAP_INCLUDE_EXT=ts,tsx,js,jsx,mjs,cjs,py,go,rs,java,kt,cs,cpp,c,h,hpp
OBSIDIAN_CODEMAP_EXCLUDE_DIRS=.git,.obsidian,node_modules,dist,build,coverage,.next,out,target
OBSIDIAN_CODEMAP_WATCH=false
OBSIDIAN_CODEMAP_WATCH_DEBOUNCE_MS=1500
OBSIDIAN_CODEMAP_TAG_BASE=code-map
OBSIDIAN_CODEMAP_TAG_FILE=code-file,code/file
OBSIDIAN_CODEMAP_TAG_SYMBOL=symbol,code/symbol
OBSIDIAN_CODEMAP_TAG_SYMBOL_KIND_PREFIX=symbol
OBSIDIAN_CODEMAP_TAG_INDEX=index
OBSIDIAN_CODEMAP_TAG_PATH_ENABLED=false
OBSIDIAN_CODEMAP_TAG_PATH_PREFIX=code/path
OBSIDIAN_CODEMAP_TAG_PATH_DEPTH=3
OBSIDIAN_CODEMAP_TAG_INCLUDE_EXTENSION=false
OBSIDIAN_CODEMAP_TAG_INLINE_ENABLED=false
OBSIDIAN_CODEMAP_ARCH_TAG_RULES=src/discord:arch/discord,src/services/obsidian:arch/obsidian,src/services/skills:arch/skills,src/routes:arch/api,src/mcp:arch/mcp,scripts:arch/tooling,docs:arch/docs
# Daily/CI cycle convenience
OBSIDIAN_VERIFY_GUILD_ID=
OBSIDIAN_OPS_LOOP_INTERVAL_SEC=300
OBSIDIAN_OPS_STEP_TIMEOUT_SEC=900
OBSIDIAN_OPS_RETRY_COUNT=1
OBSIDIAN_OPS_MAX_FAILURE_RATE=0.4
OBSIDIAN_OPS_ALL_GUILDS=false
# Auto bootstrap on discord guildCreate
OBSIDIAN_AUTO_BOOTSTRAP_ON_GUILD_JOIN=true
OBSIDIAN_AUTO_BOOTSTRAP_FORCE=false
OBSIDIAN_AUTO_BOOTSTRAP_RUN_OPS_CYCLE=false
OBSIDIAN_AUTO_BOOTSTRAP_OPS_TIMEOUT_SEC=1200
OBSIDIAN_AUTO_TOPOLOGY_SYNC_ON_GUILD_JOIN=true
OBSIDIAN_AUTO_TOPOLOGY_SYNC_ON_READY=true

# Discord answer feedback/reward signal loop
DISCORD_ENABLE_FEEDBACK_PROMPT=true
DISCORD_FEEDBACK_PROMPT_LINE=-# 이 응답이 마음에 드셨나요? 반응으로 알려주세요.
DISCORD_SESSION_PROGRESS_TIMEOUT_MS=180000

# Memory runner throughput tuning
MEMORY_JOBS_ENABLED=true
MEMORY_JOBS_POLL_INTERVAL_MS=20000
MEMORY_JOBS_CONCURRENCY=2

# Memory retrieval citation tuning
MEMORY_CITATIONS_PER_ITEM=3
MEMORY_CITATIONS_REFILL_CONCURRENCY=4
DISCORD_SESSION_PROGRESS_INTERVAL_MS=2200
DISCORD_SESSION_PROGRESS_UPDATE_BUCKET_MS=10000
DISCORD_SESSION_RESULT_CLIP_LIMIT_DEBUG=1700
DISCORD_SESSION_RESULT_CLIP_LIMIT_USER=1200
# Agent runtime latency guardrails (recommended for interactive Discord UX)
AGENT_SESSION_TIMEOUT_MS=120000
AGENT_STEP_TIMEOUT_MS=45000
AGENT_SESSION_MAX_ATTEMPTS=1
AGENT_SLO_ALERT_LOOP_CONCURRENCY=4
OPENCODE_PILOT_POLICY_ENFORCE_CONCURRENCY=4
# Dynamic reasoning budget (reduces branch fan-out for short/easy requests)
AGENT_DYNAMIC_REASONING_BUDGET_ENABLED=true
AGENT_DYNAMIC_REASONING_LOW_GOAL_LENGTH=120
AGENT_DYNAMIC_REASONING_HIGH_GOAL_LENGTH=320
# LangGraph executor shadow replay (phase-1.5 integration)
LANGGRAPH_EXECUTOR_SHADOW_ENABLED=false
LANGGRAPH_EXECUTOR_SHADOW_SAMPLE_RATE=0.2
LANGGRAPH_EXECUTOR_SHADOW_MAX_STEPS=60
# Weekly latency report sink routing (supabase,obsidian,markdown,stdout)
# Primary recommendation: supabase,obsidian (markdown is optional legacy artifact)
LLM_WEEKLY_REPORT_SINKS=supabase,obsidian
LLM_WEEKLY_REPORT_ALLOW_MISSING_TABLE=true
DISCORD_CODING_INTENT_PATTERN=(코드|코딩|구현|함수|클래스|버그|리팩터|script|typescript|javascript|python|sql|api\s*만들|코드\s*짜|만들어|짜줘|작성해줘)
DISCORD_AUTOMATION_INTENT_PATTERN=(자동화|봇|워커|연동|알림|크롤|webhook|api.*만들|자동.*전송|데이터.*수집|주기적|스케줄)
DISCORD_EMBED_DESCRIPTION_LIMIT=3900
DISCORD_ADMIN_SUMMARY_LIMIT=2000
DISCORD_ADMIN_DETAILS_LIMIT=1000
DISCORD_DOCS_MESSAGE_LIMIT=1900
DISCORD_DOCS_CONTEXT_LIMIT=4000
DISCORD_DOCS_ANSWER_LIMIT=1400
DISCORD_DOCS_FALLBACK_CONTEXT_LIMIT=600
DISCORD_MARKET_ANALYSIS_LIMIT=3900

# Channel-level activity telemetry snapshot
DISCORD_CHANNEL_TELEMETRY_ENABLED=true
DISCORD_CHANNEL_TELEMETRY_FLUSH_EVERY_EVENTS=40
DISCORD_CHANNEL_TELEMETRY_MAX_CHANNELS=30
DISCORD_CHANNEL_TELEMETRY_MAX_USERS=30

# Reaction reward signal (👍 / 😡)
DISCORD_REACTION_REWARD_ENABLED=true
DISCORD_REACTION_REWARD_FLUSH_EVERY_EVENTS=10
DISCORD_REACTION_REWARD_MAX_MESSAGES=40
DISCORD_REACTION_REWARD_MAX_USERS=40
# Retrieval eval / shadow / auto-tuning
RETRIEVAL_EVAL_DEFAULT_TOP_K=5
RETRIEVAL_SHADOW_VARIANTS=intent_prefix,keyword_expansion
RETRIEVAL_TUNING_MIN_CASES=30
RETRIEVAL_TUNING_MIN_NDCG_DELTA=0.03
# Optional runtime loop: periodic retrieval eval + optional auto-tuning
RETRIEVAL_AUTO_EVAL_ENABLED=false
RETRIEVAL_AUTO_EVAL_INTERVAL_HOURS=24
RETRIEVAL_AUTO_EVAL_RUN_ON_START=false
# Empty means evaluate all enabled cases in guild scope
RETRIEVAL_AUTO_EVAL_SET_ID=
RETRIEVAL_AUTO_EVAL_TOP_K=5
RETRIEVAL_AUTO_EVAL_MAX_GUILDS=30
RETRIEVAL_AUTO_EVAL_APPLY_TUNING=false
# RAG cache TTL in milliseconds (1 hour default)
OBSIDIAN_RAG_CACHE_TTL_MS=3600000
# Maximum documents to fetch per query
OBSIDIAN_RAG_MAX_DOCS=10
# Enable/disable caching layer
OBSIDIAN_RAG_CACHE_ENABLED=true

# Generic action runner safety controls
ACTION_RUNNER_MODE=execute
# Run goal actions only when the goal looks action-oriented (recommended true for low latency)
OPS_EXECUTION_ACTION_RUNNER_ENABLED=true
ACTION_ALLOWED_ACTIONS=*
ACTION_NEWS_CAPTURE_ENABLED=true
ACTION_NEWS_CAPTURE_TTL_MS=21600000
ACTION_NEWS_CAPTURE_MIN_ITEMS=2
ACTION_NEWS_CAPTURE_MAX_AGE_HOURS=72
ACTION_NEWS_CAPTURE_ALLOW_GUILDS=
ACTION_NEWS_CAPTURE_DENY_GUILDS=
ACTION_NEWS_CAPTURE_DENY_USERS=
ACTION_NEWS_CAPTURE_ALLOWED_DOMAINS=
ACTION_WEB_FETCH_ALLOWED_HOSTS=
ACTION_DB_READ_ALLOWED_TABLES=guild_lore_docs,memory_items
ACTION_DB_READ_MAX_ROWS=5
ACTION_POLICY_TABLE=agent_action_policies
ACTION_APPROVAL_TABLE=agent_action_approval_requests
PLANNER_SELF_CONSISTENCY_ENABLED=true
PLANNER_SELF_CONSISTENCY_SAMPLES=3
PLANNER_SELF_CONSISTENCY_TEMPERATURE=0.35
AGENT_PRIVACY_GUARDED_DEFAULT=true
AGENT_PRIVACY_REVIEW_SCORE=60
AGENT_PRIVACY_BLOCK_SCORE=80

# ─── Web Search (web.search action) ───────────────────────────
# Optional: Serper.dev API key for Google-quality results (https://serper.dev)
# If absent, falls back to DuckDuckGo HTML scraping (no key required)
SERPER_API_KEY=
WEB_SEARCH_MAX_RESULTS=5
ACTION_APPROVAL_TTL_MS=3600000

# MCP worker delegation (keep core slim)
ACTION_MCP_DELEGATION_ENABLED=true
ACTION_MCP_STRICT_ROUTING=false
ACTION_MCP_TIMEOUT_MS=8000
MCP_YOUTUBE_WORKER_URL=http://localhost:3810
MCP_NEWS_WORKER_URL=http://localhost:3810
MCP_COMMUNITY_WORKER_URL=http://localhost:3810
MCP_WEB_WORKER_URL=http://localhost:3810
MCP_YOUTUBE_DEFAULT_WEBHOOK_URL=
CRAWLER_WORKER_PORT=3810
CRAWLER_WORKER_FETCH_TIMEOUT_MS=12000
CRAWLER_WORKER_WEB_ALLOWED_HOSTS=
COMMUNITY_PLUGIN_ORDER=reddit,hackernews,stub
COMMUNITY_PLUGIN_ENABLED=*

# YouTube subscription monitor -> MCP worker offload
YOUTUBE_MONITOR_MCP_WORKER_URL=http://localhost:3810
YOUTUBE_MONITOR_MCP_TIMEOUT_MS=12000
YOUTUBE_MONITOR_MCP_STRICT=true

# News monitor -> MCP worker offload
NEWS_MONITOR_MCP_WORKER_URL=http://localhost:3810
NEWS_MONITOR_MCP_TIMEOUT_MS=12000
NEWS_MONITOR_MCP_STRICT=true

# MCP Upstream Proxy — expose external HTTP MCP servers as upstream.* tools
# JSON array of UpstreamMcpServerConfig objects:
#   { "id": string, "url": string, "namespace": string, "token"?: string, "enabled"?: boolean }
# namespace must be lowercase alphanumeric + underscore (e.g. "supabase", "deepwiki")
# Tools appear as: upstream.<namespace>.<toolName>
# Example (single line):
# MCP_UPSTREAM_SERVERS=[{"id":"supabase","url":"https://mcp.supabase.com/mcp?project_ref=YOUR_PROJECT_REF","namespace":"supabase","token":"sbp_xxx"},{"id":"deepwiki","url":"https://mcp.deepwiki.com/mcp","namespace":"deepwiki"}]
MCP_UPSTREAM_SERVERS=
# TTL in ms for upstream tool catalog cache (default: 300000 = 5 minutes)
MCP_UPSTREAM_TOOL_CACHE_TTL_MS=300000

# Privacy / right-to-be-forgotten controls
FORGET_ON_GUILD_DELETE=true
FORGET_OBSIDIAN_ENABLED=true

# FinOps controls
FINOPS_ENABLED=true
FINOPS_CACHE_TTL_MS=60000
FINOPS_DAILY_BUDGET_USD=5
FINOPS_MONTHLY_BUDGET_USD=100
FINOPS_DEGRADE_THRESHOLD_PCT=0.9
FINOPS_HARD_BLOCK_THRESHOLD_PCT=1.0
FINOPS_DEGRADE_ALLOWED_ACTIONS=rag.retrieve,stock.quote,stock.chart,privacy.forget.user,privacy.forget.guild
FINOPS_HARD_BLOCK_EXEMPT_ACTIONS=privacy.forget.user,privacy.forget.guild
FINOPS_ACTION_BASE_COST_USD=0.002
FINOPS_ACTION_RETRY_COST_USD=0.0008
FINOPS_ACTION_DURATION_MS_COST_USD=0.0000015
FINOPS_ACTION_FAILURE_PENALTY_USD=0.0007
FINOPS_RETRIEVAL_QUERY_COST_USD=0.0006
FINOPS_MEMORY_JOB_COST_USD=0.0012
ACTION_FINOPS_DEGRADED_RETRY_MAX=1
ACTION_FINOPS_DEGRADED_TIMEOUT_MS=8000
FINOPS_BUDGET_FETCH_LOG_THROTTLE_MS=300000
AGENT_POLICY_CACHE_ERROR_LOG_THROTTLE_MS=300000
AGENT_WORKFLOW_CACHE_ERROR_LOG_THROTTLE_MS=300000
AGENT_SKILL_CATALOG_CACHE_ERROR_LOG_THROTTLE_MS=300000
WORKER_APPROVAL_SAVE_ERROR_LOG_THROTTLE_MS=300000

# Runtime alert noise control for partial automation failures
RUNTIME_ALERT_AUTOMATION_PARTIAL_FAIL_MIN_COUNT=2
RUNTIME_ALERT_AUTOMATION_PARTIAL_FAIL_MIN_RATIO=0.5

# OpenJarvis unattended control-plane defaults
# route mode: auto infers by scope/objective, delivery forces fixed chain, operations forces classified routing
OPENJARVIS_ROUTE_MODE=auto
OPENJARVIS_SCOPE=weekly:auto
OPENJARVIS_STAGE=A
OPENJARVIS_OBJECTIVE=weekly unattended autonomy cycle
OPENJARVIS_REQUIRE_OPENCODE_WORKER=true
AUTONOMY_DRY_RUN=false
AUTONOMY_AUTO_DEPLOY=false
AUTONOMY_STRICT=true
AUTONOMY_AUTO_COMMIT_REPORTS=false

# Agent runtime readiness gate (evaluation / safety / observability)
AGENT_READINESS_WINDOW_DAYS=30
AGENT_READINESS_FAIL_OPEN=false
AGENT_READINESS_ALLOW_WARN=false
AGENT_READINESS_REQUIRE_RETRIEVAL_EVAL=true
AGENT_READINESS_RETRIEVAL_MAX_AGE_HOURS=168
AGENT_READINESS_MIN_RETRIEVAL_NDCG=0.45
AGENT_READINESS_MAX_ACTION_FAILURE_RATE=0.35
AGENT_READINESS_MAX_ACTION_MISSING_TOTAL=5
AGENT_READINESS_MAX_ACTION_POLICY_BLOCK_RATE=0.5
AGENT_READINESS_MIN_OBSERVED_RUNS=5
AGENT_READINESS_MIN_WORKER_GENERATION_SUCCESS_RATE=0.4
AGENT_READINESS_MIN_WORKER_APPROVAL_PASS_RATE=0.3
AGENT_READINESS_MIN_WORKER_APPROVAL_SAMPLES=3

# Go / No-Go thresholds (configurable; avoid hardcoded release gates)
GO_NO_GO_MIN_CITATION_RATE=0.95
GO_NO_GO_MAX_UNRESOLVED_CONFLICT_RATE=0.05
GO_NO_GO_MAX_JOB_FAILURE_RATE=0.10
GO_NO_GO_MIN_RECALL_AT_5=0.60
GO_NO_GO_MIN_PILOT_GUILDS=3
GO_NO_GO_MAX_CORRECTION_SLA_P95_MIN=5

# ─── External Tool Layer ───────────────────────────
# Enable external tool probe at startup and /agent/tools/external endpoint
EXTERNAL_TOOL_PROBE_ENABLED=false

# NVIDIA OpenShell sandbox runtime
# OPENSHELL_ENABLED=false
# OPENSHELL_REMOTE_GATEWAY=user@host
# OPENSHELL_SANDBOX_DELEGATION=false
# OPENSHELL_DEFAULT_SANDBOX_ID=
# OPENSHELL_DEFAULT_SANDBOX_IMAGE=ollama

# NVIDIA NemoClaw (requires OpenShell)
# NEMOCLAW_ENABLED=false
# NEMOCLAW_SANDBOX_NAME=muel-assistant
# NEMOCLAW_INFERENCE_MODEL=qwen2.5:7b-instruct
# NEMOCLAW_SANDBOX_OLLAMA_URL=http://localhost:11434
# NVIDIA_API_KEY=

# NVIDIA Nemotron via NIM API
# NVIDIA_NIM_API_KEY=

# OpenClaw always-on assistant
# OPENCLAW_ENABLED=false
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=

# Stanford OpenJarvis (open-jarvis/OpenJarvis)
# OPENJARVIS_ENABLED=false
# OPENJARVIS_SERVE_URL=http://127.0.0.1:8000
# OPENJARVIS_MODEL=

# DeepWiki adapter (plan/retro enrichment)
# DEEPWIKI_ADAPTER_ENABLED=false

# Sprint cross-model NemoClaw outside voice
# SPRINT_CROSS_MODEL_NEMOCLAW_ENABLED=false

# n8n Workflow Automation (self-hosted)
# N8N_ENABLED=false
# N8N_BASE_URL=http://localhost:5678
# N8N_API_KEY=
# N8N_TIMEOUT_MS=30000

# n8n Delegation — route automation workloads to n8n webhooks
# Master switch (default false). Requires N8N_ENABLED=true as well.
# N8N_DELEGATION_ENABLED=false
# Delegation-first mode: when true, n8n failure does NOT fall back to inline
# N8N_DELEGATION_FIRST=false
# Availability cache TTL in ms (default 60000 = 1 min, avoids healthz probe per tick)
# N8N_AVAILABILITY_CACHE_TTL_MS=60000
# Per-task webhook paths (empty = inline fallback)
# N8N_WEBHOOK_NEWS_RSS_FETCH=
# N8N_WEBHOOK_NEWS_SUMMARIZE=
# N8N_WEBHOOK_NEWS_MONITOR_CANDIDATES=
# N8N_WEBHOOK_YOUTUBE_FEED_FETCH=
# N8N_WEBHOOK_YOUTUBE_COMMUNITY_SCRAPE=
# N8N_WEBHOOK_ALERT_DISPATCH=
# N8N_WEBHOOK_ARTICLE_CONTEXT_FETCH=

# Pipeline Engine (judgment loop with chaining/branching/replanning)
# PIPELINE_MODE_ENABLED=false
# PIPELINE_MAX_STEPS=20
# PIPELINE_MAX_REPLAN_ATTEMPTS=2
# PIPELINE_PARALLEL_ENABLED=true
# PIPELINE_DATA_FLOW_ENABLED=true

# LiteLLM Proxy (also configurable above as primary — these are for local dev override)
# LITELLM_BASE_URL=http://127.0.0.1:4000
# LITELLM_MASTER_KEY=
# LITELLM_MODEL=muel-balanced

# WSL distro for OpenShell/NemoClaw on Windows
# WSL_DISTRO=Ubuntu-24.04

# Signal Bus (cross-cutting event hub)
# SIGNAL_BUS_ENABLED=true
# SIGNAL_BUS_WIRING_ENABLED=true
# SIGNAL_BUS_COOLDOWN_MS=60000

# DeepWiki adapter (repository knowledge)
# DEEPWIKI_ADAPTER_ENABLED=true
# DEEPWIKI_BASE_URL=https://api.deepwiki.com
# DEEPWIKI_TIMEOUT_MS=15000

# Render API adapter (self-management: deploys, logs, metrics)
# RENDER_API_KEY=rnd_xxxxxxxx
# RENDER_API_BASE_URL=https://api.render.com/v1
# RENDER_TIMEOUT_MS=15000
# RENDER_ADAPTER_DISABLED=false
# RENDER_WORKSPACE_ID=
