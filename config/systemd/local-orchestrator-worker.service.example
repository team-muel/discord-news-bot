[Unit]
Description=Muel Local Orchestrator Worker
After=network.target

[Service]
Type=simple
User=muel
WorkingDirectory=/opt/muel/muel-platform
EnvironmentFile=/opt/muel/muel-platform/config/env/local-orchestrator-worker.env
ExecStart=/usr/bin/node --import tsx /opt/muel/muel-platform/scripts/agent-role-worker.ts --role=local-orchestrator
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/muel/muel-platform

[Install]
WantedBy=multi-user.target
