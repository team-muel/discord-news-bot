[Unit]
Description=Muel Opencode Local Worker
After=network.target

[Service]
Type=simple
User=muel
WorkingDirectory=/opt/muel/discord-news-bot
EnvironmentFile=/opt/muel/discord-news-bot/config/env/opencode-worker.gcp.env
ExecStart=/usr/bin/node /opt/muel/discord-news-bot/scripts/opencode-local-worker.mjs
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/muel/discord-news-bot

[Install]
WantedBy=multi-user.target
