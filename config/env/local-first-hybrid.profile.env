# Local-first hybrid profile (local reasoning + remote execution worker)
AI_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_PROVIDER_BASE_ORDER=ollama,litellm,openjarvis,openclaw,anthropic,openai,gemini,huggingface
LLM_PROVIDER_FALLBACK_CHAIN=litellm,openjarvis,openclaw,anthropic,openai,gemini,huggingface
LLM_PROVIDER_POLICY_ACTIONS=skill.ops-plan=ollama,anthropic;skill.ops-critique=ollama,anthropic;skill.ops-execution=ollama,openclaw,anthropic;skill.ops-execution.fallback=openclaw,anthropic,openai;skill.ops-execution.react_reflect=ollama,anthropic;intent.route=ollama,openclaw;intent.clarify=ollama,openclaw;chat.casual=ollama;ltm.decompose=ollama,openclaw;ltm.execute_subgoal=ollama,openclaw;tot.*=ollama;compose.self_consistency_variant=ollama,anthropic;worker.generation=openjarvis,ollama,openclaw,anthropic;operate.ops=openjarvis,ollama,openclaw,anthropic;openjarvis.ops=openjarvis,ollama,openclaw,anthropic;eval.*=openjarvis,ollama,openclaw,anthropic
LLM_WORKFLOW_MODEL_BINDINGS=operate.ops=openjarvis:qwen2.5:7b-instruct;openjarvis.ops=openjarvis:qwen2.5:7b-instruct;eval.*=openjarvis:qwen2.5:7b-instruct;worker.*=openjarvis:qwen2.5:7b-instruct
LLM_WORKFLOW_PROFILE_DEFAULTS=operate.ops=quality-optimized;openjarvis.ops=quality-optimized;eval.*=quality-optimized;worker.*=quality-optimized;action.code.*=cost-optimized;chat.*=cost-optimized;memory.*=cost-optimized
LLM_PROVIDER_AUTOMATIC_FALLBACK_ENABLED=false
OPENJARVIS_REQUIRE_OPENCODE_WORKER=true
MCP_IMPLEMENT_WORKER_URL=https://34.56.232.61.sslip.io
MCP_OPENCODE_TOOL_NAME=opencode.run
ACTION_MCP_STRICT_ROUTING=true
OPENJARVIS_ROUTE_MODE=auto
ACTION_MCP_DELEGATION_ENABLED=true
OPENCODE_LOCAL_WORKER_PORT=8787
OPENCODE_LOCAL_WORKER_ALLOW_WRITE=false

# Obsidian remote-mcp (shared GCP vault service)
OBSIDIAN_REMOTE_MCP_ENABLED=true
MCP_SHARED_MCP_URL=https://34.56.232.61.sslip.io/mcp
OBSIDIAN_REMOTE_MCP_URL=https://34.56.232.61.sslip.io/mcp
OBSIDIAN_ADAPTER_ORDER=remote-mcp,local-fs
OBSIDIAN_ADAPTER_ORDER_READ_LORE=remote-mcp,local-fs
OBSIDIAN_ADAPTER_ORDER_SEARCH_VAULT=remote-mcp,local-fs
OBSIDIAN_ADAPTER_ORDER_READ_FILE=remote-mcp,local-fs
OBSIDIAN_ADAPTER_ORDER_GRAPH_METADATA=remote-mcp,local-fs
OBSIDIAN_ADAPTER_ORDER_WRITE_NOTE=remote-mcp,local-fs
# OBSIDIAN_REMOTE_MCP_TOKEN falls back to MCP_WORKER_AUTH_TOKEN when omitted

# Optional filtered shared Supabase read plane.
# Use this for diagnostics and schema visibility only; keep mutation and admin flows separate.
# MCP_UPSTREAM_SERVERS=[{"id":"supabase-ro","label":"Shared Supabase Read Plane","url":"https://mcp.supabase.com/mcp?project_ref=YOUR_PROJECT_REF","namespace":"supabase_ro","token":"sbp_xxx","protocol":"streamable","enabled":true,"plane":"operational","audience":"shared","owner":"team-muel","sourceRepo":"team-muel/discord-news-bot","toolAllowlist":["get_*","list_*","*_advisors","*_migrations","*_branches","*_logs"]}]

# Sprint pipeline (dry-run for local hybrid testing)
SPRINT_ENABLED=true
SPRINT_AUTONOMY_LEVEL=approve-impl
SPRINT_DRY_RUN=true
SPRINT_GIT_ENABLED=false

# External Tool Layer (Phase 1-4 integration)
EXTERNAL_TOOL_PROBE_ENABLED=true
OPENJARVIS_ENABLED=true
OPENJARVIS_SERVE_URL=http://127.0.0.1:8000
OPENJARVIS_MODEL=qwen2.5:7b-instruct
LITELLM_ENABLED=true
LITELLM_BASE_URL=http://127.0.0.1:4000
LITELLM_MODEL=muel-local

# NVIDIA external tools (enable when installed in WSL)
OPENSHELL_ENABLED=true
NEMOCLAW_ENABLED=true
NEMOCLAW_SANDBOX_NAME=muel-assistant
NEMOCLAW_INFERENCE_MODEL=qwen2.5:7b-instruct

# Cross-model outside voice — prefer NemoClaw sandbox for fault isolation
SPRINT_CROSS_MODEL_ENABLED=true
SPRINT_CROSS_MODEL_PROVIDER=muel-nemotron
SPRINT_CROSS_MODEL_NEMOCLAW_ENABLED=true

# Self-learning loop
JARVIS_TRACE_FEED_ENABLED=true

# Scope guard for self-modification safety
SPRINT_SCOPE_GUARD_ENABLED=true
SPRINT_SCOPE_GUARD_ALLOWED_DIRS=src/services,src/utils,src/routes
SPRINT_SCOPE_GUARD_PROTECTED_FILES=src/config.ts,src/app.ts,src/bot.ts,server.ts,bot.ts,package.json,tsconfig.json

# QA/ops-validate in OpenShell sandbox for fault isolation
SPRINT_FAST_PATH_SANDBOX_ENABLED=true
SPRINT_FAST_PATH_SANDBOX_ID=muel-assistant

# Recursive self-improvement loop (Stage 1: observe + evaluate)
SELF_IMPROVEMENT_CONVERGENCE_ENABLED=true
SELF_IMPROVEMENT_CROSS_LOOP_TRACKING_ENABLED=true
# Stage 2: trigger sprints (approve-impl gate active)
SELF_IMPROVEMENT_LACUNA_SPRINT_ENABLED=true
SELF_IMPROVEMENT_LACUNA_SPRINT_MIN_SCORE=20
SELF_IMPROVEMENT_LACUNA_SPRINT_MIN_COUNT=5
SELF_IMPROVEMENT_BUGFIX_TRIGGER_ENABLED=true
SELF_IMPROVEMENT_BENCH_REGRESSION_ENABLED=true
