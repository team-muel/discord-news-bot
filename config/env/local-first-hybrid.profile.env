# Local-first hybrid profile (local reasoning + remote execution worker)
AI_PROVIDER=ollama
OLLAMA_MODEL=mistral:latest
OLLAMA_BASE_URL=http://127.0.0.1:11434
LLM_PROVIDER_BASE_ORDER=ollama,litellm,openjarvis,openclaw,anthropic,openai,gemini,huggingface
LLM_PROVIDER_FALLBACK_CHAIN=litellm,openjarvis,openclaw,anthropic,openai,gemini,huggingface
LLM_PROVIDER_POLICY_ACTIONS=skill.ops-plan=ollama,anthropic;skill.ops-critique=ollama,anthropic;skill.ops-execution=ollama,openclaw,anthropic;skill.ops-execution.fallback=openclaw,anthropic,openai;skill.ops-execution.react_reflect=ollama,anthropic;intent.route=ollama,openclaw;intent.clarify=ollama,openclaw;chat.casual=ollama;ltm.decompose=ollama,openclaw;ltm.execute_subgoal=ollama,openclaw;tot.*=ollama;compose.self_consistency_variant=ollama,anthropic
LLM_PROVIDER_AUTOMATIC_FALLBACK_ENABLED=false
OPENJARVIS_REQUIRE_OPENCODE_WORKER=true
MCP_OPENCODE_WORKER_URL=https://34.56.232.61.sslip.io
MCP_OPENCODE_TOOL_NAME=opencode.run
ACTION_MCP_STRICT_ROUTING=true
OPENJARVIS_ROUTE_MODE=auto
ACTION_MCP_DELEGATION_ENABLED=true
OPENCODE_LOCAL_WORKER_PORT=8787
OPENCODE_LOCAL_WORKER_ALLOW_WRITE=false

# Sprint pipeline (dry-run for local hybrid testing)
SPRINT_ENABLED=true
SPRINT_AUTONOMY_LEVEL=approve-impl
SPRINT_DRY_RUN=true
SPRINT_GIT_ENABLED=false

# External Tool Layer (Phase 1-4 integration)
EXTERNAL_TOOL_PROBE_ENABLED=true
OPENJARVIS_ENABLED=true
OPENJARVIS_SERVE_URL=http://127.0.0.1:8000
OPENJARVIS_MODEL=qwen2.5:7b-instruct
LITELLM_ENABLED=true
LITELLM_BASE_URL=http://127.0.0.1:4000
LITELLM_MODEL=muel-local

# NVIDIA external tools (enable when installed in WSL)
OPENSHELL_ENABLED=true
NEMOCLAW_ENABLED=true
NEMOCLAW_SANDBOX_NAME=muel-assistant
NEMOCLAW_INFERENCE_MODEL=qwen2.5:7b-instruct

# Cross-model outside voice (Nemotron 120B via LiteLLM)
SPRINT_CROSS_MODEL_ENABLED=true
SPRINT_CROSS_MODEL_PROVIDER=muel-nemotron

# Self-learning loop
JARVIS_TRACE_FEED_ENABLED=true
