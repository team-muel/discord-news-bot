# GCP VM NemoClaw role-worker environment
NODE_ENV=production
AGENT_ROLE_WORKER_ROLE=nemoclaw
AGENT_ROLE_WORKER_PORT=8792
AGENT_ROLE_WORKER_HOST=0.0.0.0
AGENT_ROLE_WORKER_REQUIRE_AUTH=true
# Match MCP_WORKER_AUTH_TOKEN in Render env
# AGENT_ROLE_WORKER_AUTH_TOKEN=<generate-with: openssl rand -hex 32>

# LLM provider for code review actions
AI_PROVIDER=openclaw
OPENCLAW_BASE_URL=https://muel-litellm-proxy.onrender.com
# OPENCLAW_API_KEY=<must-match-LITELLM_MASTER_KEY>
OPENCLAW_MODEL=muel-balanced

# NVIDIA API key for NemoClaw sandbox inference
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_NIM_API_KEY=nvapi-...

# LLM fallback chain for sandbox inference
# When sandbox Ollama is unavailable, falls back to host LLM providers
NEMOCLAW_LLM_FALLBACK=openjarvis,litellm,ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
