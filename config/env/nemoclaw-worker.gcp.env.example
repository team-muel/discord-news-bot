# GCP VM NemoClaw role-worker environment
NODE_ENV=production
AGENT_ROLE_WORKER_ROLE=nemoclaw
AGENT_ROLE_WORKER_PORT=8792
AGENT_ROLE_WORKER_HOST=0.0.0.0
AGENT_ROLE_WORKER_REQUIRE_AUTH=true
# Match MCP_WORKER_AUTH_TOKEN in Render env
# AGENT_ROLE_WORKER_AUTH_TOKEN=<generate-with: openssl rand -hex 32>

# LLM provider for code review actions
AI_PROVIDER=litellm

# LiteLLM proxy (used by NemoClaw lite mode for code.review)
LITELLM_BASE_URL=https://muel-litellm-proxy.onrender.com
# LITELLM_MASTER_KEY=<must-match-LITELLM_MASTER_KEY>
LITELLM_MODEL=muel-balanced

# NemoClaw adapter — lite mode (sandbox is still not part of the single-node always-on baseline)
# Lite mode: code.review via LiteLLM proxy inference
NEMOCLAW_ENABLED=true

# NVIDIA API key for NemoClaw sandbox inference (only if Docker available)
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_NIM_API_KEY=nvapi-...
