# GCP VM OpenJarvis role-worker environment
NODE_ENV=production
AGENT_ROLE_WORKER_ROLE=openjarvis
AGENT_ROLE_WORKER_PORT=8793
AGENT_ROLE_WORKER_HOST=0.0.0.0
AGENT_ROLE_WORKER_REQUIRE_AUTH=true
# Match MCP_WORKER_AUTH_TOKEN in Render env
# AGENT_ROLE_WORKER_AUTH_TOKEN=<generate-with: openssl rand -hex 32>

# LLM provider for ops-validate actions
AI_PROVIDER=openjarvis

# LiteLLM proxy (used by adapter lite mode fallback)
LITELLM_BASE_URL=https://muel-litellm-proxy.onrender.com
# LITELLM_MASTER_KEY=<must-match-LITELLM_MASTER_KEY>
LITELLM_MODEL=muel-balanced

# OpenJarvis adapter — full mode (e2-medium 4GB baseline, CLI installed via setup-gcp-openjarvis.sh)
# CLI uses LiteLLM engine for inference; keep local Ollama optional, not a required always-on dependency.
OPENJARVIS_ENABLED=true
OPENJARVIS_SERVE_URL=http://127.0.0.1:8000
OPENJARVIS_MODEL=muel-balanced
