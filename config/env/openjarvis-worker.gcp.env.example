# GCP VM OpenJarvis role-worker environment
NODE_ENV=production
AGENT_ROLE_WORKER_ROLE=openjarvis
AGENT_ROLE_WORKER_PORT=8793
AGENT_ROLE_WORKER_HOST=0.0.0.0
AGENT_ROLE_WORKER_REQUIRE_AUTH=true
# Match MCP_WORKER_AUTH_TOKEN in Render env
# AGENT_ROLE_WORKER_AUTH_TOKEN=<generate-with: openssl rand -hex 32>

# LLM provider for ops-validate actions
AI_PROVIDER=openclaw
OPENCLAW_BASE_URL=https://muel-litellm-proxy.onrender.com
# OPENCLAW_API_KEY=<must-match-LITELLM_MASTER_KEY>
OPENCLAW_MODEL=muel-balanced

# OpenJarvis serve URL (local to this VM if jarvis serve is running)
OPENJARVIS_SERVE_URL=http://127.0.0.1:8000
OPENJARVIS_MODEL=qwen2.5:7b-instruct

# Ollama for local inference (OpenJarvis engine backend)
OLLAMA_BASE_URL=http://127.0.0.1:11434
