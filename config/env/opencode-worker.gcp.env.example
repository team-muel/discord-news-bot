# GCP VM opencode worker example env
NODE_ENV=production
OPENCODE_LOCAL_WORKER_HOST=0.0.0.0
OPENCODE_LOCAL_WORKER_PORT=8787
OPENCODE_LOCAL_WORKER_ROOT=/opt/muel/muel-platform
OPENCODE_LOCAL_WORKER_TIMEOUT_MS=120000
OPENCODE_LOCAL_WORKER_MAX_OUTPUT_CHARS=12000
OPENCODE_LOCAL_WORKER_ALLOW_WRITE=false
