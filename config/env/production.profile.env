# Production profile (remote worker required)
OPENJARVIS_REQUIRE_OPENCODE_WORKER=true
ACTION_MCP_STRICT_ROUTING=true
OPENJARVIS_ROUTE_MODE=auto
ACTION_MCP_DELEGATION_ENABLED=true
# Required separately:
# MCP_OPENCODE_WORKER_URL=https://<remote-worker-url>

# Sprint pipeline (production — approve-ship default)
SPRINT_ENABLED=true
SPRINT_AUTONOMY_LEVEL=approve-ship
SPRINT_DRY_RUN=false
SPRINT_GIT_ENABLED=true
# Required separately:
# SPRINT_GITHUB_TOKEN=ghp_...
# SPRINT_GITHUB_OWNER=your-org
# SPRINT_GITHUB_REPO=discord-news-bot
