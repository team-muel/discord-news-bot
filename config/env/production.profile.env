# Production profile (remote worker required)
OPENJARVIS_REQUIRE_OPENCODE_WORKER=true
ACTION_MCP_STRICT_ROUTING=true
OPENJARVIS_ROUTE_MODE=auto
ACTION_MCP_DELEGATION_ENABLED=true
# Required separately (set in Render env vars or here):
MCP_IMPLEMENT_WORKER_URL=http://34.56.232.61:8787
MCP_ARCHITECT_WORKER_URL=http://34.56.232.61:8791
MCP_REVIEW_WORKER_URL=http://34.56.232.61:8792
MCP_OPERATE_WORKER_URL=http://34.56.232.61:8793
OPENJARVIS_SERVE_URL=http://34.56.232.61:8000
# MCP_WORKER_AUTH_TOKEN=<set-matching-token-on-both-sides>

# Obsidian remote-mcp (shared GCP vault service)
OBSIDIAN_REMOTE_MCP_ENABLED=true
OBSIDIAN_REMOTE_MCP_URL=http://34.56.232.61:8850
OBSIDIAN_ADAPTER_ORDER=remote-mcp,script-cli
OBSIDIAN_ADAPTER_ORDER_READ_LORE=remote-mcp,script-cli
OBSIDIAN_ADAPTER_ORDER_SEARCH_VAULT=remote-mcp
OBSIDIAN_ADAPTER_ORDER_READ_FILE=remote-mcp
OBSIDIAN_ADAPTER_ORDER_GRAPH_METADATA=remote-mcp
OBSIDIAN_ADAPTER_ORDER_WRITE_NOTE=remote-mcp,script-cli
# OBSIDIAN_REMOTE_MCP_TOKEN falls back to MCP_WORKER_AUTH_TOKEN when omitted

# LLM fallback chain ??production resilience
# Render has LiteLLM proxy with anthropic/gemini/openai backends
LLM_PROVIDER_FALLBACK_CHAIN=openclaw,litellm,anthropic,openai,gemini
LITELLM_ENABLED=true
LITELLM_BASE_URL=https://muel-litellm-proxy.onrender.com
# LITELLM_MASTER_KEY=<set-in-render-secrets>
LITELLM_MODEL=muel-balanced

# Sprint pipeline (production ??approve-ship default)
SPRINT_ENABLED=true
SPRINT_AUTONOMY_LEVEL=approve-ship
SPRINT_DRY_RUN=false
SPRINT_GIT_ENABLED=true
# Required separately:
# SPRINT_GITHUB_TOKEN=ghp_...
SPRINT_GITHUB_OWNER=muel-s
SPRINT_GITHUB_REPO=muel-platform

# Sprint learning journal ??Supabase fallback (no Obsidian vault in Render)
# Journal writes/reads fall back to sprint_journal_entries table in Supabase
SPRINT_LEARNING_JOURNAL_ENABLED=true
SPRINT_LEARNING_JOURNAL_AUTO_APPLY_ENABLED=true
SPRINT_LEARNING_JOURNAL_AUTO_APPLY_MIN_CONFIDENCE=0.75
