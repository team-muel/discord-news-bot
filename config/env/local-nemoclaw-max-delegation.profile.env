# NemoClaw-centered max-delegation profile.
# Keep direct local reasoning on host Ollama and local n8n on the workstation,
# but wire the canonical always-on control plane to the GCP worker lane so the
# 24-hour unattended path uses remote role workers, shared MCP, and OpenJarvis
# serve by default. Discord remains a replaceable ingress, not the ownership
# boundary.

AI_PROVIDER=ollama
OLLAMA_MODEL=hf.co/bartowski/nvidia_Llama-3.1-Nemotron-Nano-8B-v1-GGUF:Q4_K_M
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Keep host OpenClaw ingress on the dev-profile port so NemoClaw can retain
# the default 18789 dashboard forward during sandbox onboarding.
OPENCLAW_ENABLED=true
OPENCLAW_GATEWAY_ENABLED=true
OPENCLAW_GATEWAY_URL=http://127.0.0.1:19001
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_BASE_URL=http://127.0.0.1:19001
OPENCLAW_API_KEY=
# Keep the OpenClaw/Hermes tool lane on a model that actually passes embedded
# tool runs locally. Nemotron stays on the main reasoning lane via Ollama,
# OpenJarvis, and NemoClaw sandbox inference.
OPENCLAW_MODEL=ollama/qwen2.5:7b
LLM_PROVIDER_BASE_ORDER=ollama,litellm,openjarvis,openclaw,anthropic,openai,gemini,huggingface
LLM_PROVIDER_FALLBACK_CHAIN=litellm,openjarvis,openclaw,anthropic,openai,gemini,huggingface
LLM_PROVIDER_POLICY_ACTIONS=skill.ops-plan=ollama,anthropic;skill.ops-critique=ollama,anthropic;skill.ops-execution=ollama,openclaw,anthropic;skill.ops-execution.fallback=openclaw,anthropic,openai;skill.ops-execution.react_reflect=ollama,anthropic;intent.route=ollama,openclaw;intent.clarify=ollama,openclaw;chat.casual=ollama;ltm.decompose=ollama,openclaw;ltm.execute_subgoal=ollama,openclaw;tot.*=ollama;compose.self_consistency_variant=ollama,anthropic;worker.generation=openjarvis,ollama,openclaw,anthropic;operate.ops=openjarvis,ollama,openclaw,anthropic;openjarvis.ops=openjarvis,ollama,openclaw,anthropic;eval.*=openjarvis,ollama,openclaw,anthropic
LLM_WORKFLOW_MODEL_BINDINGS=operate.ops=openjarvis:muel-balanced;openjarvis.ops=openjarvis:muel-balanced;eval.*=openjarvis:muel-balanced;worker.*=openjarvis:muel-balanced
LLM_WORKFLOW_PROFILE_DEFAULTS=operate.ops=quality-optimized;openjarvis.ops=quality-optimized;eval.*=quality-optimized;worker.*=quality-optimized;action.code.*=cost-optimized;chat.*=cost-optimized;memory.*=cost-optimized
LLM_PROVIDER_AUTOMATIC_FALLBACK_ENABLED=false
OPENJARVIS_REQUIRE_OPENCODE_WORKER=true
MCP_IMPLEMENT_WORKER_URL=https://34.56.232.61.sslip.io
MCP_ARCHITECT_WORKER_URL=https://34.56.232.61.sslip.io/architect
MCP_REVIEW_WORKER_URL=https://34.56.232.61.sslip.io/review
MCP_OPERATE_WORKER_URL=https://34.56.232.61.sslip.io/operate
MCP_OPENCODE_TOOL_NAME=opencode.run
ACTION_MCP_STRICT_ROUTING=true
OPENJARVIS_ROUTE_MODE=auto
ACTION_MCP_DELEGATION_ENABLED=true
OPENCODE_LOCAL_WORKER_PORT=8787
OPENCODE_LOCAL_WORKER_ALLOW_WRITE=false

# Local n8n runtime is expected to be seeded and active in this profile.
N8N_DISABLED=false
N8N_ENABLED=true
N8N_BASE_URL=http://127.0.0.1:5678
N8N_TIMEOUT_MS=30000
N8N_DELEGATION_ENABLED=true
# Fail closed for configured n8n tasks so inline fetch/scrape paths stay thin.
N8N_DELEGATION_FIRST=true
N8N_WEBHOOK_NEWS_RSS_FETCH=muel/news-rss-fetch
N8N_WEBHOOK_NEWS_SUMMARIZE=muel/news-summarize
N8N_WEBHOOK_NEWS_MONITOR_CANDIDATES=muel/news-monitor-candidates
N8N_WEBHOOK_YOUTUBE_FEED_FETCH=muel/youtube-feed-fetch
N8N_WEBHOOK_YOUTUBE_COMMUNITY_SCRAPE=muel/youtube-community-scrape
# Keep runtime alerts on the inline webhook path until a real n8n sink is wired.
N8N_WEBHOOK_ALERT_DISPATCH=
N8N_WEBHOOK_ARTICLE_CONTEXT_FETCH=muel/article-context-fetch
NEWS_MONITOR_LOCAL_FALLBACK_ENABLED=false
YOUTUBE_MONITOR_LOCAL_FALLBACK_ENABLED=false
# Optional after creating a personal API key in the n8n UI:
# N8N_API_KEY=

# Obsidian remote-mcp (shared GCP vault service)
OBSIDIAN_LOCAL_FS_ENABLED=true
OBSIDIAN_NATIVE_CLI_ENABLED=true
OBSIDIAN_REMOTE_MCP_ENABLED=true
MCP_SHARED_MCP_URL=https://34.56.232.61.sslip.io/mcp
OBSIDIAN_REMOTE_MCP_URL=https://34.56.232.61.sslip.io/mcp
OBSIDIAN_ADAPTER_ORDER=local-fs,native-cli,remote-mcp
OBSIDIAN_ADAPTER_ORDER_READ_LORE=local-fs,native-cli,remote-mcp
OBSIDIAN_ADAPTER_ORDER_SEARCH_VAULT=local-fs,native-cli,remote-mcp
OBSIDIAN_ADAPTER_ORDER_READ_FILE=local-fs,native-cli,remote-mcp
OBSIDIAN_ADAPTER_ORDER_GRAPH_METADATA=local-fs,native-cli,remote-mcp
OBSIDIAN_ADAPTER_ORDER_WRITE_NOTE=local-fs,native-cli,remote-mcp
OBSIDIAN_ADAPTER_ORDER_DAILY_NOTE=native-cli,remote-mcp
OBSIDIAN_ADAPTER_ORDER_TASK_MANAGEMENT=native-cli,remote-mcp

# Sprint pipeline (dry-run for local hybrid testing)
SPRINT_ENABLED=true
SPRINT_AUTONOMY_LEVEL=approve-impl
SPRINT_DRY_RUN=true
SPRINT_GIT_ENABLED=false

# External Tool Layer (shared GCP control plane + local acceleration)
EXTERNAL_TOOL_PROBE_ENABLED=true
OPENJARVIS_ENABLED=true
OPENJARVIS_SERVE_URL=https://34.56.232.61.sslip.io/openjarvis
OPENJARVIS_ENGINE=litellm
OPENJARVIS_AGENT=simple
OPENJARVIS_MODEL=muel-balanced
LITELLM_ENABLED=true
LITELLM_BASE_URL=http://127.0.0.1:4000
LITELLM_MODEL=muel-local

# NVIDIA external tools (enable when installed in WSL)
OPENSHELL_ENABLED=true
OPENSHELL_SANDBOX_DELEGATION=true
OPENSHELL_DEFAULT_SANDBOX_ID=muel-assistant
OPENSHELL_DEFAULT_SANDBOX_IMAGE=ollama
NEMOCLAW_ENABLED=true
NEMOCLAW_SANDBOX_NAME=muel-assistant
NEMOCLAW_INFERENCE_MODEL=hf.co/bartowski/nvidia_Llama-3.1-Nemotron-Nano-8B-v1-GGUF:Q4_K_M
NEMOCLAW_SANDBOX_OLLAMA_URL=http://host.docker.internal:11434

# NemoClaw non-interactive onboarding hints
NEMOCLAW_PROVIDER=ollama
NEMOCLAW_MODEL=hf.co/bartowski/nvidia_Llama-3.1-Nemotron-Nano-8B-v1-GGUF:Q4_K_M

# Cross-model outside voice — prefer NemoClaw sandbox for fault isolation
SPRINT_CROSS_MODEL_ENABLED=true
SPRINT_CROSS_MODEL_PROVIDER=muel-nemotron
SPRINT_CROSS_MODEL_NEMOCLAW_ENABLED=true

# Self-learning loop
OPENJARVIS_LEARNING_LOOP_ENABLED=true
OPENJARVIS_MEMORY_SYNC_ENABLED=true
JARVIS_BENCH_BENCHMARK=latency
JARVIS_BENCH_SAMPLES=1
OPENJARVIS_OPTIMIZE_DYNAMIC_PROFILE_ENABLED=true
OPENJARVIS_OPTIMIZE_BENCHMARK=
OPENJARVIS_OPTIMIZE_CONFIG=config/runtime/openjarvis-local-first-optimize.toml
OPENJARVIS_OPTIMIZE_MODEL=hf.co/bartowski/nvidia_Llama-3.1-Nemotron-Nano-8B-v1-GGUF:Q4_K_M
OPENJARVIS_OPTIMIZE_ENGINE=ollama
OPENJARVIS_OPTIMIZE_JUDGE_MODEL=hf.co/bartowski/nvidia_Llama-3.1-Nemotron-Nano-8B-v1-GGUF:Q4_K_M
OPENJARVIS_OPTIMIZE_JUDGE_ENGINE=ollama
OPENJARVIS_OPTIMIZE_TRIALS=1
OPENJARVIS_OPTIMIZE_MAX_SAMPLES=1
JARVIS_TRACE_FEED_ENABLED=true

# Scope guard for self-modification safety
SPRINT_SCOPE_GUARD_ENABLED=true
SPRINT_SCOPE_GUARD_ALLOWED_DIRS=src/services,src/utils,src/routes
SPRINT_SCOPE_GUARD_PROTECTED_FILES=src/config.ts,src/app.ts,src/bot.ts,server.ts,bot.ts,package.json,tsconfig.json

# QA/ops-validate in OpenShell sandbox for fault isolation
SPRINT_FAST_PATH_SANDBOX_ENABLED=true
SPRINT_FAST_PATH_SANDBOX_ID=muel-assistant

# Recursive self-improvement loop (Stage 1: observe + evaluate)
SELF_IMPROVEMENT_CONVERGENCE_ENABLED=true
SELF_IMPROVEMENT_CROSS_LOOP_TRACKING_ENABLED=true
# Stage 2: trigger sprints (approve-impl gate active)
SELF_IMPROVEMENT_LACUNA_SPRINT_ENABLED=true
SELF_IMPROVEMENT_LACUNA_SPRINT_MIN_SCORE=20
SELF_IMPROVEMENT_LACUNA_SPRINT_MIN_COUNT=5
SELF_IMPROVEMENT_BUGFIX_TRIGGER_ENABLED=true
SELF_IMPROVEMENT_BENCH_REGRESSION_ENABLED=true