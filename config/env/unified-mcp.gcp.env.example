# Shared MCP runtime overrides for the GCP VM.
# Copy to config/env/unified-mcp.gcp.env on the VM only when you need per-service overrides.
# The shared MCP runtime is intended to run from a non-git mirror so publish does not dirty a checkout.

NODE_ENV=production
MCP_HTTP_PORT=8850

# Shared repo index defaults for the published runtime mirror.
INDEXING_MCP_REPO_ID=current
INDEXING_MCP_REPO_ROOT=/opt/muel/shared-mcp-runtime
INDEXING_MCP_REPOS_JSON=[{"id":"current","root":"/opt/muel/shared-mcp-runtime"}]

# Uncomment these only if you want the shared HTTP surface gated by a bearer token.
# Keep both names aligned for older clients that still send MCP_WORKER_AUTH_TOKEN.
# MCP_SHARED_MCP_TOKEN=
# MCP_WORKER_AUTH_TOKEN=

# Optional: expose a filtered, read-only Supabase MCP surface beside shared Obsidian.
# Contract:
# - Obsidian remains the semantic owner for durable meaning, decisions, and graph traversal.
# - Supabase MCP is a read-only operational plane for diagnostics, schema state, advisors, logs, and migration visibility.
# - External execution runtimes or wiki services should join as separate namespace lanes rather than sharing this VM checkout.
# - Keep write, DDL, and admin-only flows off the shared team surface.
# MCP_UPSTREAM_SERVERS=[{"id":"supabase-ro","label":"Shared Supabase Read Plane","url":"https://mcp.supabase.com/mcp?project_ref=YOUR_PROJECT_REF","namespace":"supabase_ro","token":"sbp_xxx","protocol":"streamable","enabled":true,"plane":"operational","audience":"shared","owner":"team-muel","sourceRepo":"team-muel/discord-news-bot","toolAllowlist":["get_*","list_*","*_advisors","*_migrations","*_branches","*_logs"]},{"id":"external-projection","label":"External Projection Runtime","url":"https://runtime.example.com/mcp","namespace":"exec_projection","protocol":"streamable","enabled":true,"plane":"execution","audience":"shared","owner":"team-runtime","sourceRepo":"team-runtime/projection-runtime","toolAllowlist":["project_*","refresh_*","status_*"]}]