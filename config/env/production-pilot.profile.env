# Production Pilot Profile — activates dormant capabilities on a pilot guild
# Apply via PROFILE=production-pilot or merge into Render env for one guild
# Observation period: 2 weeks minimum before expanding to all guilds

# ── Lever 1: Profile-Based Activation ────────────────────────────────────────

# ToT shadow evaluation (compare ToT vs baseline in background)
TOT_SHADOW_ENABLED=true
TOT_ACTIVE_ENABLED=true
TOT_ACTIVE_ALLOW_FAST=false
TOT_ACTIVE_MIN_GOAL_LENGTH=60
TOT_ACTIVE_MIN_SCORE_GAIN=4
TOT_AUTO_TUNE_ENABLED=true
TOT_AUTO_TUNE_INTERVAL_HOURS=24

# GoT cutover (allow GoT to activate when quality criteria are met)
GOT_CUTOVER_FAIL_OPEN=false
GOT_ACTIVE_ROLLOUT_PERCENT=100
GOT_CUTOVER_MIN_RUNS=20
GOT_CUTOVER_MIN_SCORE_DELTA=0

# Cross-model voice (NemoClaw second opinion for review phases)
SPRINT_CROSS_MODEL_ENABLED=true
SPRINT_CROSS_MODEL_PROVIDER=muel-nemotron
SPRINT_CROSS_MODEL_PHASES=review,security-audit
SPRINT_CROSS_MODEL_NEMOCLAW_ENABLED=true

# Self-improvement loop (observe + evaluate + trigger sprints)
SELF_IMPROVEMENT_CONVERGENCE_ENABLED=true
SELF_IMPROVEMENT_CROSS_LOOP_TRACKING_ENABLED=true
SELF_IMPROVEMENT_LACUNA_SPRINT_ENABLED=true
SELF_IMPROVEMENT_LACUNA_SPRINT_MIN_SCORE=20
SELF_IMPROVEMENT_LACUNA_SPRINT_MIN_COUNT=5
SELF_IMPROVEMENT_BUGFIX_TRIGGER_ENABLED=true
SELF_IMPROVEMENT_BENCH_REGRESSION_ENABLED=true
SELF_IMPROVEMENT_BENCH_REGRESSION_WEEKS=2

# Memory evolution and consolidation (small-guild-friendly thresholds)
MEMORY_CONSOLIDATION_ENABLED=true
MEMORY_CONSOLIDATION_INTERVAL_MS=10800000
MEMORY_CONSOLIDATION_MIN_GROUP_SIZE=2
MEMORY_CONSOLIDATION_MAX_BATCH=10
MEMORY_CONSOLIDATION_RAW_AGE_HOURS=3
MEMORY_EVOLUTION_ENABLED=true
MEMORY_EVOLUTION_MAX_LINKS=8
MEMORY_EVOLUTION_MIN_SIMILARITY=0.20
MEMORY_EVOLUTION_CONFIDENCE_BOOST=0.04

# Entity Nervous System — all circuits (already default=true, explicit here)
ENTITY_NERVOUS_SYSTEM_ENABLED=true
ENTITY_MEMORY_PRECIPITATION_ENABLED=true
ENTITY_MEMORY_PRECIPITATION_MIN_STEPS=1
ENTITY_REWARD_BEHAVIOR_ENABLED=true
ENTITY_SELF_NOTES_ENABLED=true
ENTITY_SELF_NOTES_MAX_ITEMS=15

# LangGraph executor shadow replay (validate graph fidelity)
LANGGRAPH_EXECUTOR_SHADOW_ENABLED=true
LANGGRAPH_EXECUTOR_SHADOW_SAMPLE_RATE=0.20

# Sprint learning journal mutation (lower confidence threshold for pilot)
SPRINT_LEARNING_JOURNAL_AUTO_APPLY_MIN_CONFIDENCE=0.65

# Scope guard (self-mod safety, keep on even in pilot)
SPRINT_SCOPE_GUARD_ENABLED=true
SPRINT_SCOPE_GUARD_ALLOWED_DIRS=src/services,src/utils,src/routes
SPRINT_SCOPE_GUARD_PROTECTED_FILES=src/config.ts,src/app.ts,src/bot.ts,server.ts,bot.ts,package.json,tsconfig.json

# ── Lever 3: GCP Worker Enhanced (requires e2-small upgrade) ─────────────────

# When GCP VM is upgraded to e2-small (2GB), enable full jarvis serve:
# OPENJARVIS_SERVE_URL=http://34.56.232.61:8000
# The jarvis serve systemd unit runs continuously for 24/7 learning loop
# jarvis.bench + jarvis.optimize run on the GCP VM directly (no WSL dependency)
JARVIS_TRACE_FEED_ENABLED=true
