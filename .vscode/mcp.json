{
  "servers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "muelIndexing": {
      "type": "stdio",
      "command": "npm",
      "args": [
        "run",
        "mcp:indexing:dev"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "INDEXING_MCP_REPO_ID": "current",
        "INDEXING_MCP_REPO_ROOT": "${workspaceFolder}"
      }
    },
    "muelUnified": {
      "type": "stdio",
      "command": "npm",
      "args": [
        "run",
        "mcp:unified:dev"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "INDEXING_MCP_REPO_ID": "current",
        "INDEXING_MCP_REPO_ROOT": "${workspaceFolder}"
      }
    },
    "gcpCompute": {
      "type": "stdio",
      "command": "ssh",
      "args": [
        "-o",
        "StrictHostKeyChecking=accept-new",
        "-o",
        "LogLevel=ERROR",
        "-i",
        "${env:USERPROFILE}/.ssh/google_compute_engine",
        "fancy@34.56.232.61",
        "cd /opt/muel/discord-news-bot && if [ -f .env ]; then set -a && . ./.env && set +a; fi && if [ -f config/env/unified-mcp.gcp.env ]; then set -a && . config/env/unified-mcp.gcp.env && set +a; fi && exec node --import tsx scripts/unified-mcp-stdio.ts"
      ]
    }
  }
}
